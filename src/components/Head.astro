---
const { pageName } = Astro.props
import { useI18n } from '~/i18n/utils'
import { isStaging } from '~/utils/build/isStaging'

const base = import.meta.env.BASE_URL
const t = useI18n(Astro.url.pathname)
---

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{pageName} | g0v Summit 2026</title>
  <meta name="description" content={t.meta.description} />
  <meta property="og:title" content="g0v Summit 2026" />
  <meta property="og:description" content={t.meta.description} />
  <meta property="og:image" content="https://summit.g0v.tw/2026/img/share.jpg" />
  <meta property="og:url" content="https://summit.g0v.tw/2026" />
  <meta property="og:type" content="website" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="g0v Summit 2026" />
  <meta name="twitter:description" content={t.meta.description} />
  <meta name="twitter:image" content="https://summit.g0v.tw/2026/img/share.jpg" />
  {isStaging() && <meta name="robots" content="noindex" />}

  <link rel="icon" type="image/svg" href="favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="crossorigin" />
  <link href="https://fonts.googleapis.com/css2?family=Onest:wght@100..900&family=Noto+Sans+TC:wght@100..900&display=swap" rel="stylesheet" />
  <base href={base} />

  <!-- Google tag (gtag.js) -->
  <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-SPHXWCG6TN"></script>
  <script is:inline>
    window.dataLayer = window.dataLayer || []
    function gtag() {
      dataLayer.push(arguments)
    }
    gtag('js', new Date())
    gtag('config', 'G-SPHXWCG6TN')
  </script>
</head>
