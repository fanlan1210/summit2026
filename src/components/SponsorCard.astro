---
import { useI18n } from '~/i18n/utils'
import Icon from '~/components/Icon.astro'

const { name, description, site, img, tier } = Astro.props
const { t } = useI18n(Astro.url.pathname)
---

<div class={`sponsor-card group relative overflow-hidden rounded-xl border-2 border-neutral-300 bg-white p-6`}>
  <div class="flex flex-col gap-4 sm:flex-row sm:gap-6">
    <!-- Logo -->
    <div class="aspect-square h-24 w-24 shrink-0 overflow-hidden rounded-lg bg-neutral-50 p-2 sm:h-28 sm:w-28">
      <img class="h-full w-full object-contain" src={`./img/partners/${img}`} alt={name} />
    </div>

    <!-- Info -->
    <div class="flex flex-1 flex-col justify-center">
      <div class="mb-2 flex items-center gap-3">
        <h4 class="text-lg font-bold text-neutral-800">{name}</h4>
        <span class={`ms-auto shrink-0 inline-block rounded-full px-3 py-0.5 text-xs font-semibold bg-primary text-white`}>
          {t(`sponsor.tiers.${tier}`)}
        </span>
      </div>

      <div class="flex flex-wrap gap-2">
        {
          site && (
            <a href={site} target="_blank" rel="noopener noreferrer" class="btn btn-outline-primary btn-sm w-fit gap-1.5 text-sm">
              {t('sponsor.site')}
              <Icon name="material-symbols:open-in-new" width="14" height="14" />
            </a>
          )
        }

        {
          description && (
            <button type="button" class="sponsor-description-trigger btn btn-outline-primary btn-sm w-fit gap-1.5 text-sm" aria-haspopup="dialog">
              {t('sponsor.description')}
              <Icon name="material-symbols:info-outline" width="14" height="14" />
            </button>
          )
        }
      </div>
    </div>
  </div>

  {
    description && (
      <div class="modal-content hidden">
        <div class="body">
          <div class="mb-5 flex justify-center">
            <div>
              <div class="mb-4 flex items-center gap-4">
                <div class="aspect-square h-20 w-20 shrink-0 overflow-hidden rounded-lg bg-neutral-50 p-2 md:hidden">
                  <img class="h-full w-full object-contain" src={`./img/partners/${img}`} alt={name} />
                </div>
                <h2 class="text-xl font-bold text-neutral-800">{name}</h2>
              </div>
              <div class="text-base leading-relaxed whitespace-pre-line text-neutral-700" set:html={description} />
            </div>
            <div class="hidden aspect-square h-48 w-48 shrink-0 overflow-hidden rounded-lg bg-neutral-50 p-2 md:block">
              <img class="h-full w-full object-contain" src={`./img/partners/${img}`} alt={name} />
            </div>
          </div>
        </div>
      </div>
    )
  }
</div>

<script>
  import { showModalWith } from '~/utils/client/modal'

  document.querySelectorAll('.sponsor-description-trigger').forEach(trigger => {
    trigger.addEventListener('click', e => {
      const card = (e.currentTarget as HTMLElement).closest('.sponsor-card')
      const body = card?.querySelector('.modal-content .body')
      if (!body) return

      showModalWith({
        header: null,
        body: body.innerHTML,
        size: 'lg',
      })
    })
  })
</script>
