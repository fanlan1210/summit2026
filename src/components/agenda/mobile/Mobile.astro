---
import { getRelativeLocaleUrl } from 'astro:i18n'
import { getLocaleFromPath } from '~/i18n/utils'
import schedule from '~/data/schedule.json'
import { extractHHmm } from '~/utils/build/agenda/extractHHmm'
import SessionGrid from '~/components/agenda/SessionGrid.astro'
import DayLink from '~/components/agenda/DayLink.astro'
import Search from '~/components/agenda/Search.astro'
import Icon from '~/components/Icon.astro'

const locale = getLocaleFromPath(Astro.url.pathname)
const { title, date } = Astro.props

const sessions = schedule.sessions.filter(session => session.start.startsWith(date))
const rooms = schedule.rooms.map(room => room.id)

const allSessions = sessions.reduce((acc, session) => {
  const key = extractHHmm(session.start)
  if (!acc[key]) acc[key] = []
  acc[key].push(session)
  return acc
}, {})
const allTimes = Object.keys(allSessions).sort((a, b) => a.localeCompare(b))
---

<div class="lg:hidden">
  <div class="sticky top-0 z-30 bg-white py-2">
    <div class="container">
      <div class="mb-4 flex items-center justify-between gap-3 font-bold">
        <div class="flex justify-center gap-4">
          <DayLink href={getRelativeLocaleUrl(locale, 'agenda/day1')} title="Day 1" curTitle={title} />
          <DayLink href={getRelativeLocaleUrl(locale, 'agenda/day2')} title="Day 2" curTitle={title} />
        </div>
        <button
          id="searchToggle"
          type="button"
          class="grid h-7 w-7 shrink-0 place-items-center rounded-full border border-[#D1D1D1] text-gray-400 transition-colors"
          aria-expanded="false"
          aria-controls="mobileSearchPanel"
        >
          <Icon name="mdi:magnify" width="24" />
        </button>
      </div>
      <div id="mobileSearchPanel" class="mb-4 hidden">
        <Search />
      </div>
      <div id="btns" class="grid grid-cols-6 text-center">
        <button data-target-room="all" class="border-info-dark border-b-2 transition-colors">ALL</button>
        {
          rooms.map(room => (
            <button data-target-room={room} class="border-b-2 border-transparent transition-colors">
              {room}
            </button>
          ))
        }
      </div>
    </div>
  </div>

  <div class="container">
    <div id="mobile-sessions" class="mt-6">
      {
        allTimes.map(time => (
          <div class="time-group">
            <div>{time}</div>
            {allSessions[time].map(session => {
              if (session.id.startsWith('CT-')) return
              return <SessionGrid session={session} />
            })}
          </div>
        ))
      }
    </div>
  </div>
</div>

<script>
  import $ from 'jquery'

  const searchToggleEl = document.querySelector<HTMLButtonElement>('#searchToggle')
  const searchPanelEl = document.querySelector<HTMLElement>('#mobileSearchPanel')
  const $mobileSessions = $('#mobile-sessions')
  const $btnsChildren = $('#btns button')

  searchToggleEl?.addEventListener('click', () => {
    const isExpanded = searchToggleEl.getAttribute('aria-expanded') === 'true'
    searchToggleEl.setAttribute('aria-expanded', String(!isExpanded))
    searchToggleEl?.classList.toggle('bg-info-dark', !isExpanded)
    searchToggleEl?.classList.toggle('text-white!', !isExpanded)
    searchToggleEl?.classList.toggle('border-info-dark!', !isExpanded)
    searchPanelEl?.classList.toggle('hidden', isExpanded)
  })

  $('#btns').on('click', 'button', function () {
    resetMobileSessions()
    $(this).removeClass('border-transparent').addClass('border-info-dark')
    const targetRoom = $(this).data('target-room')

    if (targetRoom !== 'all') {
      $mobileSessions
        .find('.session[data-room]')
        .filter(function () {
          const rooms = $(this)
            .data('room')
            .split(',')
            .map(room => room.trim())
          return !rooms.includes(targetRoom)
        })
        .addClass('hidden')
    }

    syncTimeGroupVisibility()
  })

  function resetMobileSessions() {
    $btnsChildren.each(function () {
      $(this).removeClass('border-info-dark').addClass('border-transparent')
    })
    $mobileSessions.find('.session').removeClass('hidden')
  }

  function syncTimeGroupVisibility() {
    $mobileSessions.find('.time-group').each(function () {
      const hasVisibleSessions = $(this).find('.session').not('.hidden').length > 0
      $(this).toggleClass('hidden', !hasVisibleSessions)
    })
  }
</script>
