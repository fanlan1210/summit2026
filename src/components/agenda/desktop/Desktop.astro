---
import { getRelativeLocaleUrl } from 'astro:i18n'
import { getLocaleFromPath } from '~/i18n/utils'
import schedule from '~/data/schedule.json'
import { extractHHmm } from '~/utils/build/agenda/extractHHmm'
import DayLink from '~/components/agenda/DayLink.astro'
import RoomCard from '~/components/agenda/desktop/RoomCard.astro'
import Time from '~/components/agenda/desktop/Time.astro'
import SessionGrid from '~/components/agenda/SessionGrid.astro'
import Search from '~/components/agenda/Search.astro'

const locale = getLocaleFromPath(Astro.url.pathname)
const { title, date } = Astro.props

const times = new Set()
const sessions = []
schedule.sessions.forEach(session => {
  if (session.start.startsWith(date)) {
    times.add(extractHHmm(session.start))
    times.add(extractHHmm(session.end))
    sessions.push(session)
  }
})
const rooms = schedule.rooms.map(room => room.id)
// ex: [time] 4rem [R0] 1fr [R1] 1fr [R2] 1fr [R3] 1fr [RH] 1fr [end] auto
const gridTemplateColumnsStyle = '[time] 4rem ' + rooms.map(room => `[${room}] 1fr`).join(' ') + ' [end] auto'
---

<div class="agenda hidden lg:block">
  <div class="sticky top-0 z-30 mb-6 flex flex-col justify-center bg-white" style="height: var(--agenda-header-height);">
    <div class="container">
      <div class="mt-4 mb-5 flex gap-4">
        <DayLink href={getRelativeLocaleUrl(locale, 'agenda/day1')} title="Day 1" curTitle={title} />
        <DayLink href={getRelativeLocaleUrl(locale, 'agenda/day2')} title="Day 2" curTitle={title} />
        <div class="ml-auto">
          <Search />
        </div>
      </div>

      <div class="grid text-center" style={`grid-template-columns: ${gridTemplateColumnsStyle};`}>
        <div></div>
        {rooms.map(room => <RoomCard room={room} />)}
      </div>
    </div>
  </div>

  <div class="container">
    <div id="agenda-grid" class="relative grid" style={`grid-template-columns: ${gridTemplateColumnsStyle};`}>
      {Array.from(times).map(time => <Time at={time} />)}
      {
        sessions.map(session => {
          if (session.id.startsWith('CT-')) return
          return <SessionGrid session={session} />
        })
      }
    </div>
  </div>
</div>

<style is:global>
  .agenda {
    --agenda-header-height: 130px;
  }
</style>
