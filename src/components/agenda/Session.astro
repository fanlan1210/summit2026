---
import { getRelativeLocaleUrl } from 'astro:i18n'
import { micromark } from 'micromark'
import { getLocaleFromPath, useI18n } from '~/i18n/utils'
import schedule from '~/data/schedule.json'
import { extractHHmm } from '~/utils/build/agenda/extractHHmm'
import { formatHHmm, formatMMdd } from '~/utils/datetime'
import { getLocalizedSpeakerName } from '~/utils/speaker'
import SessionBadges from './SessionBadges.astro'
import { getDefaultAvatar } from '~/utils/getDefaultAvatar'

const { t } = useI18n(Astro.url.pathname)
const locale = getLocaleFromPath(Astro.url.pathname)
const isZhTW = locale === 'zh-tw'

const { session } = Astro.props
const sessionTitle = isZhTW ? session.zh.title : session.en.title || session.zh.title
const sessionDescription = isZhTW ? session.zh.description : session.en.description || session.zh.description
const sessionDescriptionHtml = micromark(sessionDescription || '')

const columnOrder = ['R0', 'R1', 'R2', 'R3', 'RH', 'end']

const speakers = session.speakers.map(speakerId => speakerIdToDetail(speakerId))
const startRow = parseInt(extractHHmm(session.start).replace(':', '')) || 0
const endRow = parseInt(extractHHmm(session.end).replace(':', '')) || 0
const [startCol, endCol] = getColumnStartEnd(session.broadcast || session.room)
const isRest = session.type === 'R'
const isEvent = session.type === 'E'
const canClick = !isRest && !isEvent

const style = `grid-area: ${startRow} / ${startCol} / ${endRow} / ${endCol};`

function getColumnStartEnd(columns) {
  columns = columns.split(',')
  if (columns.length !== 1) {
    columns.sort((a, b) => columnOrder.indexOf(a) - columnOrder.indexOf(b))
  }
  const last = columnOrder.indexOf(columns.at(-1)) + 1
  return [columns[0], columnOrder[last]]
}

function speakerIdToDetail(speakerId) {
  return schedule.speakers.find(speaker => speaker.id === speakerId)
}

function getSpeakerName(speaker) {
  return getLocalizedSpeakerName(speaker, locale)
}
---

<div class:list={['session', canClick ? 'session-canClick' : '', 'm-3 flex flex-col transition-opacity']} style={style} data-id={session.id} data-room={session.broadcast || session.room}>
  <div
    class:list={[
      'relative z-10 shrink-0 grow rounded p-4 hover:z-20',
      isRest ? 'border-info-dark bg-info/20 text-info-dark z-10 border-2 border-dashed text-center' : 'bg-[#F3F3F3]',
      canClick ? 'cursor-pointer' : '',
    ]}
  >
    <div class="sticky" style="top: calc(var(--agenda-header-height) + 1rem);">
      <div class="font-bold">{sessionTitle}</div>
      <div class="flex flex-col items-stretch">
        {speakers.map(speaker => <div class="text-sm">{getSpeakerName(speaker)}</div>)}
      </div>

      {!isRest && <SessionBadges session={session} />}
    </div>
  </div>

  {
    canClick && (
      <div class="modal-content hidden">
        <div class="header">
          <h3 class="text-info-dark">{sessionTitle}</h3>
          <SessionBadges session={session} />
          <div class="mb-2">
            {formatMMdd(session.start)} {formatHHmm(session.start)} ~ {formatHHmm(session.end)} @ {session.broadcast || session.room}
          </div>
          <div class="flex gap-2">
            {session.qa && (
              <a href={session.qa} target="_blank" class="btn btn-info">
                {t('agenda.qa')}
              </a>
            )}
            {session.co_write && (
              <a href={session.co_write} target="_blank" class="btn btn-info">
                {t('agenda.note')}
              </a>
            )}
          </div>
        </div>

        <div class="body">
          <div class="mb-4 flex flex-col gap-4">
            {speakers.map(speaker => (
              <a href={`${getRelativeLocaleUrl(locale, 'speaker')}#${encodeURIComponent(speaker.id)}`} class="group flex items-center gap-4 text-inherit no-underline">
                <div class="grid aspect-square w-24 place-items-center overflow-hidden rounded-full bg-[#f1f5f9]">
                  <img class:list={[speaker.avatar ? 'h-full w-full' : 'w-[60%]']} src={speaker.avatar || getDefaultAvatar(getSpeakerName(speaker))} alt={getSpeakerName(speaker)} />
                </div>
                <span class="text-info-dark text-xl font-bold underline-offset-4 group-hover:underline">{getSpeakerName(speaker)}</span>
              </a>
            ))}
          </div>
          <div
            class="session-description mb-0 border-t border-neutral-300 py-4 wrap-break-word leading-relaxed [&_a]:text-info-dark [&_a]:underline [&_blockquote]:border-l-4 [&_blockquote]:border-neutral-300 [&_blockquote]:pl-4 [&_code]:rounded [&_code]:bg-neutral-200 [&_code]:px-1 [&_code]:py-0.5 [&_h1]:mb-4 [&_h1]:font-bold [&_h2]:mb-4 [&_h2]:font-bold [&_h3]:mb-3 [&_h3]:font-bold [&_h4]:mb-3 [&_h4]:font-bold [&_h5]:mb-2 [&_h5]:font-bold [&_h6]:mb-2 [&_h6]:font-bold [&_li]:mb-1 [&_ol]:mb-4 [&_ol]:list-decimal [&_ol]:pl-6 [&_p]:mb-4 [&_p:last-child]:mb-0 [&_pre]:overflow-x-auto [&_pre]:rounded [&_pre]:bg-neutral-900 [&_pre]:p-4 [&_pre]:text-neutral-100 [&_ul]:mb-4 [&_ul]:list-disc [&_ul]:pl-6"
            set:html={sessionDescriptionHtml}
          />
        </div>
      </div>
    )
  }
</div>
