---
import { useI18n } from '~/i18n/utils'
import Icon from '~/components/Icon.astro'
import Layout from '~/layouts/Layout.astro'
import Desktop from './desktop/Desktop.astro'
import Mobile from './mobile/Mobile.astro'
import schedule from '~/data/schedule.json'
import OpassDownload from '~/components/OpassDownload.astro'

const { t } = useI18n(Astro.url.pathname)
const { title, date } = Astro.props
const sessions = schedule.sessions.filter(session => session.start.startsWith(date))
---

<Layout pageName={t('nav.agenda')}>
  <div class="container mb-8">
    <h1 class="mt-8 md:mt-12">{t('agenda.title')}</h1>
    <p class="mt-4 text-neutral-400">{t('agenda.info')}</p>

    <div>
      <a class="btn btn-info gap-1" target="_blank" href="https://g0v.hackmd.io/@summit2026/notes">
        <Icon name="mdi:file-text-edit" width={20} />
        {t('agenda.main_note')}
      </a>
    </div>
  </div>

  <Desktop title={title} date={date} />
  <Mobile title={title} date={date} />

  <div class="container mt-24 mb-16">
    <OpassDownload />
  </div>
</Layout>

<div id="sessionsJson" data-json={JSON.stringify(sessions)}></div>

<script>
  import Fuse from 'fuse.js'
  import { clearLocationHash, getVisibleElementFromHash, isVisible, updateLocationHash } from '~/utils/client/locationHash'
  import { showModalWith } from '~/utils/client/modal'

  const agendaGridEl = document.querySelector('#agenda-grid')
  const mobileSessionsEl = document.querySelector('#mobile-sessions')
  let isSessionModalOpen = false

  agendaGridEl?.addEventListener('click', showSessionModal)
  mobileSessionsEl?.addEventListener('click', showSessionModal)
  window.addEventListener('modal:hide', handleModalHide)
  window.addEventListener('hashchange', handleSessionHashChange)

  type OpenSessionModalOptions = {
    updateHash?: boolean
    scroll?: boolean
  }

  function openSessionModal(session: HTMLElement, { updateHash = false, scroll = false }: OpenSessionModalOptions = {}) {
    if (scroll) {
      session.scrollIntoView({ block: 'center', inline: 'nearest', behavior: 'smooth' })
    }

    if (!renderSessionModal(session)) return false

    isSessionModalOpen = true

    if (updateHash) {
      updateSessionHash(session)
    }

    return true
  }

  // Reuse the same modal HTML as clicking a session cell
  function renderSessionModal(session: HTMLElement) {
    const modalContent = getOwnModalContent(session)
    const header = modalContent?.querySelector('.header')
    const body = modalContent?.querySelector('.body')
    if (!header || !body) return false
    showModalWith({ header: header.innerHTML, body: body.innerHTML })
    return true
  }

  function showSessionModal(e: Event) {
    const target = e.target as HTMLElement
    const session = target.closest('.session.session-canClick') as HTMLElement
    if (!session) return

    openSessionModal(session, { updateHash: true })
  }

  function getOwnModalContent(session: HTMLElement) {
    if (session.classList.contains('ct-session-content')) {
      return session.querySelector('.modal-content')
    }

    return session.querySelector('.session-content .modal-content')
  }

  function updateSessionHash(session: HTMLElement) {
    const { id } = session.dataset
    updateLocationHash(id)
  }

  function handleModalHide() {
    if (!isSessionModalOpen) return

    isSessionModalOpen = false
    clearSessionHash()
  }

  function clearSessionHash() {
    clearLocationHash()
  }

  // scroll page to `#sessionId` cell and open modal
  function tryOpenSessionFromHash() {
    const session = getVisibleElementFromHash(id => `.session.session-canClick[data-id="${id}"]`)
    if (!session) return
    openSessionModal(session, { scroll: true })
  }

  function handleSessionHashChange() {
    tryOpenSessionFromHash()
  }

  requestAnimationFrame(() => tryOpenSessionFromHash())

  // Search
  const agendaSearchEls = document.querySelectorAll('.agenda-search')
  const sessionEls = document.querySelectorAll('.session')

  const sessions = JSON.parse(document.querySelector<HTMLElement>('#sessionsJson').dataset.json)
  const fuse = new Fuse(sessions, {
    keys: ['zh.title', 'en.title', 'tags'],
    threshold: 0.3,
  })

  let highestScoreElement: HTMLElement

  agendaSearchEls.forEach((el: HTMLElement) => {
    el.addEventListener('input', e => {
      const target = e.currentTarget as HTMLInputElement
      const value = target.value.trim()
      if (!value) {
        sessionEls.forEach((session: HTMLElement) => {
          session.classList.remove('opacity-30')
        })
        return
      }

      const results = fuse.search<{ id: string }>(value)
      const ids = results.map(result => result.item.id)

      if (ids.length === 0) return

      sessionEls.forEach((session: HTMLElement) => {
        if (ids[0] === session.dataset.id && isVisible(session)) {
          highestScoreElement = session
        }

        const isMatched = ids.includes(session.dataset.id)
        session.classList.toggle('opacity-30', !isMatched)
      })

      scrollElementIntoView()
    })

    el.addEventListener('keydown', e => {
      if (e.key !== 'Enter') return
      scrollElementIntoView()
    })
  })

  function scrollElementIntoView() {
    if (highestScoreElement) {
      highestScoreElement.scrollIntoView({ block: 'center', inline: 'center', behavior: 'smooth' })
    }
  }
</script>

<style is:global>
  :root {
    scroll-padding-top: 0 !important;
  }

  #navbar {
    position: relative;
  }
</style>
