---
import { useI18n } from '~/i18n/utils'
import Layout from '~/layouts/Layout.astro'
import Desktop from './desktop/Desktop.astro'
import Mobile from './mobile/Mobile.astro'
import Icon from '~/components/Icon.astro'
import schedule from '~/data/schedule.json'
import Search from '~/components/agenda/Search.astro'

const { t } = useI18n(Astro.url.pathname)
const { title, date } = Astro.props
const sessions = schedule.sessions.filter(session => session.start.startsWith(date))
---

<Layout pageName={t('nav.agenda')}>
  <div class="container">
    <h1 class="my-8 md:my-12">{t('agenda.title')}</h1>

    <div class="mb-8 flex flex-col gap-4 md:flex-row">
      <a href="#" class="btn btn-info flex gap-1 px-14!">
        <Icon name="mdi:text-box-edit" width="24" />
        <span>{t('agenda.main_note')}</span>
      </a>
      <a href="#" class="btn btn-info flex gap-1 px-14!">
        <Icon name="mdi:video" width="24" />
        <span>{t('agenda.main_live')}</span>
      </a>
      <div class="mt-6 lg:hidden">
        <Search />
      </div>
    </div>
  </div>

  <Desktop title={title} date={date} />
  <Mobile title={title} date={date} />
</Layout>

<div id="sessionsJson" data-json={JSON.stringify(sessions)}></div>

<script>
  import { showModalWith } from '~/utils/client/modal'

  const agendaGridEl = document.querySelector('#agenda-grid')
  const sessionsEl = document.querySelector('#sessions')

  agendaGridEl?.addEventListener('click', showSessionModal)
  sessionsEl?.addEventListener('click', showSessionModal)

  function showSessionModal(e: Event) {
    const target = e.target as HTMLElement
    const session = target.closest('.session')
    if (!session) return

    showModalWith({
      header: session.querySelector('.modal-content .header').innerHTML,
      body: session.querySelector('.modal-content .body').innerHTML,
    })
  }
</script>

<style is:global>
  :root {
    scroll-padding-top: 0 !important;
  }

  #navbar {
    position: relative;
  }
</style>
