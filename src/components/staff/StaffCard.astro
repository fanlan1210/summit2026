---
import AvatarImage from '~/components/AvatarImage.astro'
import Icon from '~/components/Icon.astro'
import { getLocalizedStaffName, getAvatar, onlyUrl } from '~/utils/build/staff'

const { person, locale, hasIntro = false, isLeader = false } = Astro.props
const name = getLocalizedStaffName(person, locale)
const avatar = getAvatar(person)
const leaderStool = `${import.meta.env.BASE_URL}img/banner/g0v_stool-nbg-y-s.svg`
const intro = person.intro?.trim() ?? ''
const hasUrlIntro = hasIntro && onlyUrl(intro)
const introUrl = /^https?:\/\//i.test(intro) ? intro : `https://${intro}`
const CardTag = hasUrlIntro ? 'a' : hasIntro ? 'button' : 'div'

let cardAttrs = {}
if (hasUrlIntro) {
  cardAttrs = { href: introUrl, target: '_blank', rel: 'noopener noreferrer' }
} else if (hasIntro) {
  cardAttrs = { type: 'button', 'data-id': person.id }
}
---

<CardTag class:list={['staff-card group flex min-w-0 flex-col items-center justify-start text-center text-inherit no-underline', hasIntro && 'cursor-pointer']} {...cardAttrs}>
  <div class="relative aspect-square w-full">
    {isLeader && <img class="pointer-events-none absolute top-0 left-1/2 z-10 w-6 -translate-x-1/2 -translate-y-3/5 rotate-180 sm:w-10" src={leaderStool} alt="" aria-hidden="true" />}
    <div
      class:list={[
        'ring-primary/20 flex aspect-square h-full w-full items-center justify-center overflow-hidden rounded-full bg-slate-100 ring-2 ring-offset-2 ring-offset-white transition duration-150',
        hasIntro && 'group-hover:ring-primary group-focus-visible:ring-primary',
      ]}
    >
      <AvatarImage class="h-full w-full object-cover object-top" src={avatar} alt={name} />
    </div>
    {
      hasIntro && (
        <span
          class="text-primary group-hover:bg-primary group-focus-visible:bg-primary absolute grid h-7 w-7 place-items-center rounded-full bg-white/90 shadow-sm ring-1 ring-black/10 transition duration-150 group-hover:text-white group-focus-visible:text-white"
          style="top: calc(14.6447% - 0.875rem); right: calc(14.6447% - 0.875rem);"
          aria-hidden="true"
        >
          <Icon name="mdi:chat-processing" width={20} />
        </span>
      )
    }
  </div>
  <div class:list={['mt-3 w-full leading-snug wrap-break-word transition duration-150', hasIntro && 'group-hover:text-primary group-focus-visible:text-primary']}>
    {name}
  </div>
</CardTag>
