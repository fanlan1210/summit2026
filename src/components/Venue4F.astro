---
import { getLocaleFromPath, useI18n } from '~/i18n/utils'
import Icon from '~/components/Icon.astro'
import booth_data from '~/data/booth.json'
const { t } = useI18n(Astro.url.pathname)
const locale = getLocaleFromPath(Astro.url.pathname)

const getTitle = (name_en: String) => {
  const name = booth_data.find(booth => booth.name_en === name_en)?.name
  if (!name || locale === 'en') return name_en
  return name
}
