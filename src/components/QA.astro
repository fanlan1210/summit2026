---
import { useI18n } from '~/i18n/utils'
const { t } = useI18n(Astro.url.pathname)
const { qKey, aKey } = Astro.props
---

<details class="qa group mb-3 rounded-md border border-neutral-50 bg-white p-4 shadow-sm">
  <summary class="flex cursor-pointer list-none items-center justify-between gap-4 font-semibold">
    <span>{t(qKey)}</span>
    <span class="arrow inline-block transition-transform duration-300 group-open:rotate-180">▾</span>
  </summary>
  <div class="content text-sm md:text-base">
    <p class="mt-3">{t(aKey)}</p>
  </div>
</details>

<style>
  details.qa summary::-webkit-details-marker {
    display: none;
  }
  details.qa::details-content {
    max-height: 0;
    overflow: hidden;
    opacity: 0;
    transition:
      max-height 0.3s ease,
      opacity 0.3s ease,
      content-visibility 0.3s allow-discrete;
  }
  details.qa[open]::details-content {
    max-height: 999px;
    opacity: 1;
  }
  @starting-style {
    details.qa[open]::details-content {
      max-height: 0;
      opacity: 0;
    }
  }
</style>
