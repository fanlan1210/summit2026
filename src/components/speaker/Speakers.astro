---
import Layout from '~/layouts/Layout.astro'
import Markdown from '~/components/Markdown.astro'
import { getLocaleFromPath, isMandarinPreferred, useI18n } from '~/i18n/utils'
import schedule from '~/data/schedule.json'
import { getSpeakerProfile } from '~/utils/build/speaker'
import SpeakerGridCard from './SpeakerGridCard.astro'
import { getAvatar, isDefaultAvatar } from '~/utils/build/speaker'
import AvatarImage from '~/components/AvatarImage.astro'
import { hrefForAgendaSession } from '~/utils/build/agenda/hrefForAgendaSession'
import { compareDate, formatHHmm, formatMMdd } from '~/utils/datetime'

const { t } = useI18n(Astro.url.pathname)
const locale = getLocaleFromPath(Astro.url.pathname)
const isZhTW = isMandarinPreferred(locale)

const KEYNOTE_SPEAKER_IDS = ['isabelhou', 'special', 'muhua']

const keynoteSpeakers = KEYNOTE_SPEAKER_IDS.map(id => schedule.speakers.find(s => s.id === id)).filter(Boolean)

const allSpeakersInSessions = new Set()

for (const session of schedule.sessions) {
  for (const speaker of session.speakers) {
    allSpeakersInSessions.add(speaker)
  }
}

// Hide speakers who have no id or no sessions.
const speakersForGrid = schedule.speakers.filter(
  s => String(s.id ?? '').trim() !== '' && allSpeakersInSessions.has(s.id) && !KEYNOTE_SPEAKER_IDS.includes(s.id),
)
---

<Layout pageName={t('nav.speaker')}>
  <div class="container">
    <h1 class="my-8 md:my-12">{t('nav.speaker')}</h1>

    {
      keynoteSpeakers && keynoteSpeakers.length > 0 && (
        <section class="keynote my-20">
          <h3 class="mb-12">{t('speakers.keynote')}</h3>
          {keynoteSpeakers.map(speaker => {
            const { name, otherName, bio } = getSpeakerProfile(speaker, locale)
            const sessions = schedule.sessions.filter(session => session.speakers.includes(speaker.id)).sort((a, b) => compareDate(a.start, b.start))
            return (
              <div class="speaker mb-12" data-id={speaker.id}>
                <div class="flex flex-col items-center gap-12 md:flex-row md:items-start">
                  <div class="grid aspect-square w-40 shrink-0 cursor-pointer place-items-center overflow-hidden rounded-full bg-[#f1f5f9]">
                    <AvatarImage class:list={[isDefaultAvatar(speaker) ? 'w-[60%]' : 'h-full w-full']} src={getAvatar(speaker)} alt={name} />
                  </div>
                  <div class="w-full">
                    <h5 class="mb-6">{name}</h5>
                    {bio && <p class="whitespace-pre-line">{bio}</p>}
                  </div>
                </div>

                <div class="modal-content hidden">
                  <div class="header">
                    <div class="flex items-center gap-4">
                      <div class="grid aspect-square w-14 place-items-center overflow-hidden rounded-full bg-slate-100 md:w-20">
                        <AvatarImage class:list={[isDefaultAvatar(speaker) ? 'w-1/2' : 'h-full w-full object-cover']} src={getAvatar(speaker)} alt={name} />
                      </div>
                      <div class="flex flex-col">
                        <h4 class="font-bold">{name}</h4>
                        {otherName && otherName !== name && <h6 class="text-neutral-500">{otherName}</h6>}
                      </div>
                    </div>
                  </div>
                  <div class="body">
                    {bio && <Markdown content={bio} class="speaker-bio mb-4" />}
                    {sessions.length > 0 && (
                      <div class="border-t border-neutral-300 pt-4">
                        {sessions.map(session => {
                          const title = isZhTW ? session.zh.title : session.en.title || session.zh.title
                          const info = `${formatMMdd(session.start)} ${formatHHmm(session.start)} ~ ${formatHHmm(session.end)} @ ${session.room}`
                          return (
                            <a class="mb-4 block text-inherit no-underline hover:underline" href={hrefForAgendaSession(locale, session.start, session.id)}>
                              <h5 class="font-bold">{title}</h5>
                              <div class="text-sm text-neutral-500">{info}</div>
                            </a>
                          )
                        })}
                      </div>
                    )}
                  </div>
                </div>
              </div>
            )
          })}
        </section>
      )
    }

    <section class="my-20">
      <h3 class="mb-4">{t('speakers.sessions')}</h3>
      <div id="speakers-grid" class="mb-12 grid grid-cols-3 items-start gap-6 md:grid-cols-5">
        {speakersForGrid.map(speaker => <SpeakerGridCard speaker={speaker} />)}
      </div>
    </section>
  </div>
</Layout>

<script>
  import { clearLocationHash, getVisibleElementFromHash, updateLocationHash } from '~/utils/client/locationHash'
  import { showModalWith } from '~/utils/client/modal'

  const speakersPageEl = document.querySelector('.keynote')
  let isSpeakerModalOpen = false

  type OpenSpeakerModalOptions = {
    updateHash?: boolean
    scroll?: boolean
  }

  function openSpeakerModalFromCard(speaker: HTMLElement, { updateHash = false, scroll = false }: OpenSpeakerModalOptions = {}) {
    if (scroll) {
      speaker.scrollIntoView({ block: 'center', inline: 'nearest', behavior: 'smooth' })
    }

    const header = speaker.querySelector('.modal-content .header')
    const body = speaker.querySelector('.modal-content .body')
    if (!header || !body) return false
    showModalWith({ header: header.innerHTML, body: body.innerHTML })
    isSpeakerModalOpen = true

    if (updateHash) {
      updateSpeakerHash(speaker)
    }

    return true
  }

  // Click speaker and open pop-up overlay used on the agenda page
  function showSpeakerModal(e: Event) {
    const target = e.target as HTMLElement
    if (target.tagName !== 'IMG') return
    const speaker = target.closest('.speaker[data-id]')
    if (!speaker || !(speaker instanceof HTMLElement)) return

    openSpeakerModalFromCard(speaker, { updateHash: true })
  }

  function handleModalHide() {
    if (!isSpeakerModalOpen) return

    isSpeakerModalOpen = false
    clearSpeakerHash()
  }

  function clearSpeakerHash() {
    clearLocationHash()
  }

  function updateSpeakerHash(speaker: HTMLElement) {
    const { id } = speaker.dataset
    updateLocationHash(id)
  }

  // …/speaker/#speakerId → scroll to card and open same pop-up (ref speakers.js)
  function tryOpenSpeakerFromHash() {
    const speaker = getVisibleElementFromHash(id => `.speaker[data-id="${id}"]`)
    if (!speaker) return
    openSpeakerModalFromCard(speaker, { scroll: true })
  }

  speakersPageEl?.addEventListener('click', showSpeakerModal)
  window.addEventListener('modal:hide', handleModalHide)
  requestAnimationFrame(() => tryOpenSpeakerFromHash())
</script>
