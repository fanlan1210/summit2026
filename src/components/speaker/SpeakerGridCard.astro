---
import { getRelativeLocaleUrl } from 'astro:i18n'
import { getLocaleFromPath } from '~/i18n/utils'
import schedule from '~/data/schedule.json'
import { AGENDA_DAY2_DATE } from '~/utils/build/agenda/dates'
import { formatHHmm, formatMMdd } from '~/utils/datetime'
import { getSpeakerProfile } from '~/utils/speaker'

const locale = getLocaleFromPath(Astro.url.pathname)

// Localized agenda/dayN + #sessionId for hash deep-link
function hrefForAgendaSession(start, id) {
  const day = start.startsWith(AGENDA_DAY2_DATE) ? 'agenda/day2' : 'agenda/day1'
  return `${getRelativeLocaleUrl(locale, day)}#${encodeURIComponent(id)}`
}
const isZhTW = locale === 'zh-tw'

const { speaker } = Astro.props

const { name, otherName, bio } = getSpeakerProfile(speaker, locale)
const isDefaultAvatar = !speaker.avatar || speaker.avatar.includes('default')

const sessions = schedule.sessions.filter(s => s.speakers.includes(speaker.id))
---

<div class="speaker flex cursor-pointer flex-col items-center justify-center" data-id={speaker.id}>
  <div class="flex aspect-square w-full items-center justify-center overflow-hidden rounded-full bg-slate-100">
    {isDefaultAvatar ? <img class="rounded-full" src={speaker.avatar} aria-hidden="true" /> : <img class="h-full w-full rounded-full object-cover" src={speaker.avatar} alt={name} />}
  </div>
  <div class="my-2 text-center">{name}</div>

  <div class="modal-content hidden">
    <div class="header">
      <div class="flex items-center gap-4">
        <img class="w-20 shrink-0 rounded-full bg-slate-100" src={speaker.avatar} alt={name} />
        <div class="flex flex-col">
          <h4 class="font-bold">{name}</h4>
          {otherName && otherName !== name && <h6 class="text-neutral-500">{otherName}</h6>}
        </div>
      </div>
    </div>
    <div class="body">
      {bio && <p class="mb-4 wrap-break-word whitespace-pre-line">{bio}</p>}
      {
        sessions.length > 0 && (
          <div class="border-t border-neutral-300 pt-4">
            {sessions.map(session => {
              const title = isZhTW ? session.zh.title : session.en.title
              const info = `${formatMMdd(session.start)} ${formatHHmm(session.start)} ~ ${formatHHmm(session.end)} @ ${session.room}`
              return (
                <a class="mb-4 block text-inherit no-underline hover:underline" href={hrefForAgendaSession(session.start, session.id)}>
                  <h5 class="font-bold">{title}</h5>
                  <div class="text-sm text-neutral-500">{info}</div>
                </a>
              )
            })}
          </div>
        )
      }
    </div>
  </div>
</div>
