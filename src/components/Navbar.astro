---
import { useI18n } from '~/i18n/utils'
import { pathnameWithoutBaseAndLocale } from '~/utils/build/pathnameWithoutBaseAndLocale'
import { getRelativeLocaleUrl } from 'astro:i18n'
import Icon from '~/components/Icon.astro'
import Link from '~/components/Link.astro'

const { t } = useI18n(Astro.url.pathname)
const pathname = pathnameWithoutBaseAndLocale(Astro.url.pathname)

// ── Types ────────────────────────────────────────────────────────────────────

/** A single link inside a submenu column */
interface NavSubmenuLink {
  label: string
  href: string
}

/**
 * A column inside the submenu dropdown.
 * - `title` / `titleHref` render as a large bold heading link.
 * - `links` renders as a row of smaller links separated by "|".
 */
interface NavSubmenuColumn {
  title: string
  titleHref: string
  links: NavSubmenuLink[]
}

/**
 * When a NavItem has a `submenu`, a dropdown panel is rendered automatically.
 * Add columns to describe the content — no extra HTML needed.
 */
interface NavSubmenu {
  columns: NavSubmenuColumn[]
}

interface NavItem {
  key: string
  name: string
  /** Used as the fallback link in the mobile nav */
  href: string
  submenu?: NavSubmenu
}

// ── Data ─────────────────────────────────────────────────────────────────────

const navs: NavItem[] = [
  {
    key: 'agenda',
    href: 'agenda/day1',
    name: t('nav.agenda'),
  },
  {
    key: 'visit',
    href: 'visit',
    name: t('nav.visit'),
    submenu: {
      columns: [
        {
          title: t('index.venue.title'),
          titleHref: `visit#visit-map`,
          links: [{ label: t('visit.info.venueName'), href: `visit#visit-map` }],
        },
        {
          title: t('visit.transport.title'),
          titleHref: `visit#tab-publicTransport`,
          links: [
            { label: t('visit.transport.tabs.publicTransport'), href: `visit#tab-publicTransport` },
            { label: `${t('visit.transport.tabs.drivingLine1')}${t('visit.transport.tabs.drivingLine2')}`, href: `visit#tab-driving` },
          ],
        },
      ],
    },
  },
  {
    key: 'venue',
    href: 'venue',
    name: t('nav.venue'),
  },
  {
    key: 'sponsor',
    href: 'sponsor',
    name: t('nav.sponsor'),
    submenu: {
      columns: [
        {
          title: t('sponsor.title2'),
          titleHref: `sponsor#sponsor-list`,
          links: [],
        },
        {
          title: t('sponsor.support.title'),
          titleHref: `sponsor#sponsor-support`,
          links: [],
        },
        {
          title: t('sponsor.pressKit.title'),
          titleHref: `sponsor#sponsor-presskit`,
          links: [],
        },
      ],
    },
  },
]
---

<nav id="navbar" class="sticky top-0 z-999 flex h-14 w-full items-center bg-black text-white shadow-md">
  <div class="container flex h-full items-center">
    <!-- Logo -->
    <Link id="logo" class="mr-auto" href="/">
      <img src="./img/g0v-summit-logo-w.svg" alt="g0v Summit 2026" class="h-12" />
    </Link>

    <!-- Desktop nav links -->
    <div id="navs" class="scroll-x hidden h-full min-w-0 items-center md:flex">
      {
        navs.map(nav =>
          nav.submenu ? (
            <button id={`${nav.key}-toggle`} type="button" class="nav-link" aria-haspopup="true" aria-expanded="false" aria-controls={`${nav.key}-submenu`}>
              {nav.name}
            </button>
          ) : (
            <Link class="nav-link" href={nav.href}>
              {nav.name}
            </Link>
          )
        )
      }
    </div>

    <!-- Language switcher -->
    <div class="group relative hidden h-full items-center gap-2 px-4 font-bold md:flex">
      <span class="flex cursor-pointer items-center gap-2">
        Language
        <Icon name="mdi:language" width="20" />
      </span>

      <div
        class="pointer-events-none absolute top-0 right-0 bottom-0 left-0 z-60 block w-max transform-[translateY(90%)] opacity-0 transition-[opacity,transform] group-hover:pointer-events-auto group-hover:transform-[translateY(100%)] group-hover:opacity-100"
      >
        <div class="lang-btn-group mt-1 flex flex-col">
          <button data-target={getRelativeLocaleUrl('zh-tw', pathname)} class="w-full cursor-pointer bg-black px-6 py-2 text-left text-white transition-[background-color] hover:bg-neutral-500"
            >華語</button
          >
          <button data-target={getRelativeLocaleUrl('en', pathname)} class="w-full cursor-pointer bg-black px-6 py-2 text-left text-white transition-[background-color] hover:bg-neutral-500"
            >English</button
          >
        </div>
      </div>
    </div>

    <!-- Mobile hamburger -->
    <button id="toggle-nav-btn" class="grid h-6 place-items-center md:hidden">
      <div id="burger"></div>
    </button>

    <!-- Mobile nav drawer -->
    <div id="mobile-nav" class="absolute top-full right-0 left-0 grid grid-rows-[0fr] overflow-hidden bg-black text-white transition-[grid-template-rows] md:hidden">
      <div class="container min-h-0">
        <div class="flex flex-col gap-3 pt-3 pb-6">
          {
            navs.map(nav => (
              <Link class="mobile-nav-item px-6 text-lg" href={nav.href}>
                {nav.name}
              </Link>
            ))
          }

          <div class="flex items-center gap-2 px-6 text-xl">
            <Icon name="mdi:language" width="20" />
            <a href={getRelativeLocaleUrl('zh-tw', pathname)} class="text-lg">華語</a>
            <span>|</span>
            <a href={getRelativeLocaleUrl('en', pathname)} class="text-lg">English</a>
          </div>

          <a class="register-btn btn-brand flex items-center justify-between px-4 py-3 text-lg" href="#">
            {t('nav.register')}
            <Icon name="mdi:arrow-right" width="28" />
          </a>
        </div>
      </div>
    </div>
  </div>

  <a class="register-btn btn-brand hidden h-full shrink-0 items-center justify-center px-8 md:flex" href="#">
    {t('nav.register')}
  </a>

  <!-- ── Desktop submenu panels (auto-generated from navs data) ──────────────
       To add a submenu: add a `submenu: { columns: [...] }` entry to a NavItem.
       Each column has:
         title / titleHref  →  large bold heading link
         links[]            →  row of smaller links separated by "|"
  ─────────────────────────────────────────────────────────────────────────── -->
  {
    navs
      .filter(nav => nav.submenu)
      .map(nav => (
        <div
          id={`${nav.key}-submenu`}
          class="pointer-events-none absolute top-full right-0 left-0 z-50 hidden grid-rows-[0fr] overflow-hidden bg-black text-white transition-[grid-template-rows] md:grid"
        >
          <div class="container min-h-0">
            <div class={`grid gap-8 py-12 grid-cols-${nav.submenu!.columns.length}`}>
              {nav.submenu!.columns.map(col => (
                <div class="min-w-0">
                  <Link class="submenu-link flex items-center text-2xl leading-tight font-bold tracking-wide text-white" href={col.titleHref}>
                    {col.title} <Icon name="bi:arrow-right" height="20" class="ml-2" />
                  </Link>
                  <div class={`mt-5 flex flex-wrap items-center gap-x-3 gap-y-2 text-base leading-relaxed font-normal ${col.links.length == 0 && 'hidden'}`}>
                    {col.links.map((link, i) => (
                      <>
                        {i > 0 && <span class="text-white/40">|</span>}
                        <Link class="w-fit text-white/70 transition-colors hover:text-white/90" href={link.href}>
                          {link.label}
                        </Link>
                      </>
                    ))}
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      ))
  }

  <template id="register-modal-header">
    <h1 class="mb-2">{t('nav.register')}</h1>
  </template>
  <template id="register-modal-body">
    <div class="text-[#1e1e1e]">
      <div class="mb-8">
        <a href="https://summit.g0v.tw/tickets" target="_blank" rel="noopener noreferrer" class="btn btn-primary flex items-center gap-2">
          {t('register.cta')}<Icon name="mdi:external-link" width="22" />
        </a>
      </div>

      <div class="mb-12 grid gap-8 md:grid-cols-2">
        <div class="flex flex-col">
          <h4 class="text-info-dark mb-2">{t('register.time')}</h4>
          <div class="mb-4">2026.05.23-24 | 09:00-17:30</div>
          <a
            href="https://calendar.google.com/calendar/render?action=TEMPLATE&text=g0v+Summit+2026&dates=20260523T010000Z/20260524T093000Z&details=g0v+Summit+2026&location=Academia+Sinica"
            target="_blank"
            class="btn btn-primary mt-auto flex w-fit items-center gap-2"
          >
            {t('register.add_to_calendar')}<Icon name="mdi:external-link" width="22" />
          </a>
        </div>
        <div class="flex flex-col">
          <h4 class="text-info-dark mb-2">{t('register.location')}</h4>
          <div class="mb-4">
            {t('register.location_value_1')}<br />
            <span class="text-gray-700">{t('register.location_value_2')}</span>
          </div>
          <Link href="visit" class="btn btn-primary mt-auto flex w-fit items-center gap-2">
            {t('register.transportation')}<Icon name="mdi:external-link" width="22" />
          </Link>
        </div>
      </div>

      <div class="rounded-3xl border-2 border-[#58A83F] bg-[#F6FFF3] p-6 text-[#306D13]">
        <h3 class="mb-4 text-xl font-bold">{t('agenda.dont_miss')}</h3>
        <p class="mb-6">{t('agenda.opass_info')}</p>
        <div class="flex flex-col items-start gap-4 lg:flex-row lg:items-center">
          <div class="flex items-center gap-4">
            <a href="https://play.google.com/store/apps/details?id=app.opass.ccip" target="_blank">
              <img class="h-full max-h-16" src={import.meta.env.BASE_URL + 'img/logo/google-play.png'} alt="google play" />
            </a>
            <a href="https://apps.apple.com/us/app/opass-app/id1436417025" target="_blank">
              <img class="h-full max-h-16" src={import.meta.env.BASE_URL + 'img/logo/app-store.png'} alt="app store" />
            </a>
          </div>
        </div>
      </div>
    </div>
  </template>
</nav>

<script>
  import $ from 'jquery'
  import { showModalWith } from '~/utils/client/modal'

  // ── Mobile nav toggle ────────────────────────────────────────────────────────
  const $mobileNav = $('#mobile-nav')

  $('#toggle-nav-btn').on('click', toggleMobileNav)
  $('.mobile-nav-item').on('click', toggleMobileNav)

  function toggleMobileNav() {
    $mobileNav.toggleClass('grid-rows-[0fr] grid-rows-[1fr]')
    $mobileNav.toggleClass('shadow-md')
    $('#burger').toggleClass('is-active')
  }

  // ── Register modal ───────────────────────────────────────────────────────────
  $('.register-btn').on('click', function (e) {
    e.preventDefault()
    if ($mobileNav.hasClass('grid-rows-[1fr]')) toggleMobileNav()
    showModalWith({
      header: $('#register-modal-header').html(),
      body: $('#register-modal-body').html(),
      size: 'lg',
    })
  })

  // ── Submenu helpers ──────────────────────────────────────────────────────────
  function closeSubmenu($submenu: JQuery<HTMLElement>, $toggle: JQuery<HTMLElement>) {
    $submenu.removeClass('grid-rows-[1fr]')
    $submenu.addClass('grid-rows-[0fr]')
    $submenu.removeClass('shadow-md')
    $submenu.removeClass('pointer-events-auto')
    $submenu.addClass('pointer-events-none')
    $toggle.attr('aria-expanded', 'false')
  }

  function openSubmenu($submenu: JQuery<HTMLElement>, $toggle: JQuery<HTMLElement>) {
    $submenu.addClass('grid-rows-[1fr]')
    $submenu.removeClass('grid-rows-[0fr]')
    $submenu.addClass('shadow-md')
    $submenu.addClass('pointer-events-auto')
    $submenu.removeClass('pointer-events-none')
    $toggle.attr('aria-expanded', 'true')
  }

  // ── Auto-wire every [id="*-toggle"] ↔ [id="*-submenu"] pair ─────────────────
  // Convention: button id="{key}-toggle" controls panel id="{key}-submenu".
  const toggles: Array<{ $toggle: JQuery<HTMLElement>; $submenu: JQuery<HTMLElement> }> = []

  $('[id$="-toggle"]').each(function () {
    const toggleId = $(this).attr('id')! // e.g. "visit-toggle"
    const key = toggleId.replace(/-toggle$/, '') // e.g. "visit"
    const $submenu = $(`#${key}-submenu`)
    if (!$submenu.length) return

    const $toggle = $(this)
    toggles.push({ $toggle, $submenu })

    $toggle.on('click', function () {
      const isOpen = $submenu.hasClass('grid-rows-[1fr]')

      // Close all other open submenus first
      toggles.forEach(({ $toggle: t, $submenu: s }) => {
        if (!s.is($submenu)) closeSubmenu(s, t)
      })

      if (isOpen) {
        closeSubmenu($submenu, $toggle)
      } else {
        openSubmenu($submenu, $toggle)
      }
    })

    // Close when any link inside the submenu is clicked
    $submenu.find('a').on('click', function () {
      closeSubmenu($submenu, $toggle)
    })
  })

  // Close all submenus on outside click
  $(document).on('click', function (e) {
    toggles.forEach(({ $toggle, $submenu }) => {
      if (!$toggle.is(e.target as unknown as Element) && !$submenu.find(e.target as unknown as Element).length) {
        closeSubmenu($submenu, $toggle)
      }
    })
  })

  // ── Navs horizontal scroll on trackpad / mouse-wheel ─────────────────────────
  const $navs = $('#navs')

  $navs.on('wheel', function (e) {
    const oe = e.originalEvent as WheelEvent
    const delta = Math.abs(oe.deltaX) > Math.abs(oe.deltaY) ? oe.deltaX : oe.deltaY
    const el = this
    const canScrollLeft = el.scrollLeft > 0
    const canScrollRight = el.scrollLeft + el.clientWidth < el.scrollWidth

    if ((delta < 0 && canScrollLeft) || (delta > 0 && canScrollRight)) {
      e.preventDefault()
      el.scrollBy({ left: delta, behavior: 'smooth' })
    }
  })

  // ── Language switcher ─────────────────────────────────────────────────────────
  $('.lang-btn-group button').on('click', function () {
    if (!window.location.href.split('#')[0].endsWith($(this).data('target'))) {
      window.location.href = $(this).data('target')
    }
  })
</script>

<style>
  @reference "../styles/base.css";

  #burger {
    @apply h-[2.5px] w-5 rounded-full bg-white transition-all;
    &:before,
    &:after {
      content: ' ';
      @apply absolute block h-[2.5px] w-5 rounded-full bg-white;
    }
    &:before {
      animation: burger-t-Out 0.3s ease forwards;
    }
    &:after {
      animation: burger-b-Out 0.3s ease forwards;
    }
    &.is-active {
      @apply bg-transparent;
      &:before {
        animation: burger-t-In 0.3s ease forwards;
      }
      &:after {
        animation: burger-b-In 0.3s ease forwards;
      }
    }
  }

  @keyframes burger-t-In {
    0% {
      transform: rotate(0deg) translateY(-7px);
    }
    50% {
      transform: translateY(0);
    }
    100% {
      transform: rotate(45deg);
    }
  }

  @keyframes burger-t-Out {
    0% {
      transform: rotate(45deg);
    }
    50% {
      transform: translateY(0);
    }
    100% {
      transform: rotate(0deg) translateY(-7px);
    }
  }

  @keyframes burger-b-In {
    0% {
      transform: rotate(0deg) translateY(-7px);
    }
    50% {
      transform: translateY(0);
    }
    100% {
      transform: rotate(-225deg);
    }
  }

  @keyframes burger-b-Out {
    0% {
      transform: rotate(-45deg);
    }
    50% {
      transform: translateY(0);
    }
    100% {
      transform: rotate(0deg) translateY(7px);
    }
  }

  .submenu-link {
    @apply w-fit;
    &:hover > iconify-icon {
      animation: submenuIconMouseIn 0.3s ease forwards;
    }
    &:not(:hover) > iconify-icon {
      animation: submenuIconMouseOut 0.3s ease forwards;
    }
  }

  @keyframes submenuIconMouseIn {
    0% {
      transform: translateX(0);
      opacity: 1;
      color: inherit;
    }
    49% {
      opacity: 0;
      transform: translateX(15px);
    }
    50% {
      opacity: 0;
      transform: translateX(-15px);
    }
    100% {
      transform: translateX(0);
      opacity: 1;
      color: var(--color-primary);
    }
  }

  @keyframes submenuIconMouseOut {
    0% {
      color: var(--color-primary);
    }
    100% {
      color: inherit;
    }
  }
</style>
