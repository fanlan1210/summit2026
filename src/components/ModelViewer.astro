---
import { useI18n } from '~/i18n/utils'
import Icon from '~/components/Icon.astro'
const { t } = useI18n(Astro.url.pathname)

interface Props {
  modelPath?: string
  scenePath?: string
}

const { modelPath = '', scenePath = '' } = Astro.props
---

<div class="viewer-container">
  <div class="overlay hidden">
    <span class="overlay-text">
      <Icon icon="mdi:gesture-spread" width="80" height="80" />
      {t('index.interact')}
    </span>
  </div>
  <div class="model-viewer" data-model-path={modelPath} data-scene-path={scenePath}></div>
</div>

<style>
  .viewer-container {
    position: relative;
    width: 100%;
    height: 100%;
  }

  .model-viewer {
    cursor: grab;
    width: 100%;
    height: 100%;
    opacity: 0;
    transition: opacity 1s ease;

    canvas {
      touch-action: pan-y !important;
    }
    &.loaded {
      opacity: 1;
    }
  }

  .overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0, 0, 0, 0.3);
    display: flex;
    justify-content: center;
    align-items: center;
    cursor: pointer;
    z-index: 1;
    transition: opacity 0.3s ease;
    pointer-events: none;
  }

  .overlay.hidden {
    opacity: 0;
    pointer-events: none;
  }

  .overlay-text {
    color: white;
    font-size: 1.2rem;
    font-weight: bold;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    iconify-icon {
      animation: pinchLoop 0.5s ease-in-out infinite alternate;
    }
  }
</style>

<script>
  import { initModelViewer } from '~/scripts/modelViewer'
  initModelViewer()
  const isTouchDevice = () => {
    return 'ontouchstart' in window || navigator.maxTouchPoints > 0
  }

  let isScrolling

  const overlay = document.querySelector('.overlay')

  if (isTouchDevice()) {
    document.querySelector('.viewer-container')?.addEventListener('click', function () {
      overlay?.classList.remove('hidden')
      isScrolling = setTimeout(function () {
        overlay?.classList.add('hidden')
      }, 1000)
    })
    window.addEventListener('scroll', function () {
      overlay?.classList.remove('hidden')
      window.clearTimeout(isScrolling)
      isScrolling = setTimeout(function () {
        overlay?.classList.add('hidden')
      }, 500)
    })
  }
</script>
