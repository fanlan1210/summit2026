---
import { useI18n } from '~/i18n/utils'
import Icon from '~/components/Icon.astro'
const { t } = useI18n(Astro.url.pathname)
---

<div class="viewer-container">
  <div class="overlay hidden">
    <span class="overlay-text">
      <Icon icon="mdi:gesture-spread" width="80" height="80" />
      {t('index.interact')}
    </span>
  </div>
  <div class="model-viewer"></div>
  <div class="viewer-keys">
    <button class="keycap" data-key="r">
      <span class="keycap-letter">R</span>
      <span class="keycap-label">{t('index.key.reset')}</span>
    </button>
    <button class="keycap" data-key="t">
      <span class="keycap-letter">T</span>
      <span class="keycap-label">{t('index.key.ticket')}</span>
    </button>
    <button class="keycap" data-key="Enter">
      <span class="keycap-letter"><Icon icon="boxicons:enter" width="20" height="20" /></span>
      <span class="keycap-label">{t('index.key.pangolin')}</span>
    </button>
  </div>
</div>

<style>
  @reference "~/styles/_tailwind.css";

  .viewer-container {
    @apply relative h-full w-full;
  }

  .model-viewer {
    @apply h-full w-full cursor-grab opacity-0;
    transition: opacity 1s ease;

    canvas {
      touch-action: pan-y !important;
    }
    &.loaded {
      @apply opacity-100;
    }
  }

  .overlay {
    @apply absolute inset-0 z-1 flex cursor-pointer items-center justify-center bg-black/30 pointer-events-none;
    transition: opacity 0.3s ease;
  }

  .overlay.hidden {
    @apply opacity-0 pointer-events-none;
  }

  .overlay-text {
    @apply flex flex-col items-center gap-4 text-white text-[1.2rem] font-bold;
    iconify-icon {
      animation: pinchLoop 0.5s ease-in-out infinite alternate;
    }
  }

  /* Keyboard shortcut buttons */
  .viewer-keys {
    @apply absolute bottom-8 left-1/2 z-2 hidden md:flex -translate-x-1/2 gap-3;
  }

  .keycap {
    @apply flex flex-col items-center gap-1 border-none rounded-xl cursor-pointer select-none min-w-14 backdrop-blur-sm;
    background: rgba(255, 255, 255, 0.85);
    padding: 0.5rem 0.875rem 0.4rem;
    transition: transform 0.15s ease, box-shadow 0.15s ease, background 0.15s ease;
    box-shadow:
      0 2px 0 rgba(0, 0, 0, 0.12),
      0 4px 8px rgba(0, 0, 0, 0.08);
  }

  .keycap:hover {
    background: rgba(255, 255, 255, 0.95);
    transform: translateY(-1px);
    box-shadow:
      0 3px 0 rgba(0, 0, 0, 0.14),
      0 6px 12px rgba(0, 0, 0, 0.1);
  }

  .keycap:active,
  .keycap.pressed {
    transform: translateY(2px);
    box-shadow:
      0 0 0 rgba(0, 0, 0, 0.12),
      0 1px 2px rgba(0, 0, 0, 0.08);
  }

  .keycap-letter {
    @apply text-xl font-bold leading-none text-[#1a1a1a];
  }

  .keycap-label {
    @apply text-[0.625rem] font-semibold leading-none whitespace-nowrap text-[#555] mt-auto;
  }
</style>

<script>
  import { initModelViewer } from '~/scripts/modelViewer'
  initModelViewer()
  let isScrolling
  let usingTouch = false
  let rickedRoll = false

  const overlay = document.querySelector('.overlay')
  const viewerContainer = document.querySelector('.viewer-container')

  window.addEventListener('pointerdown', (e) => {
    usingTouch = e.pointerType === 'touch'
  })

  viewerContainer?.addEventListener('click', function () {
    if (!usingTouch) return
    overlay?.classList.remove('hidden')
    isScrolling = setTimeout(function () {
      overlay?.classList.add('hidden')
    }, 1000)
  })
  window.addEventListener('scroll', function () {
    if (!usingTouch) return
    overlay?.classList.remove('hidden')
    window.clearTimeout(isScrolling)
    isScrolling = setTimeout(function () {
      overlay?.classList.add('hidden')
    }, 500)
  })

  // Keycap buttons – dispatch real keyboard events so modelViewer.ts picks them up,
  // except for "t" which opens the register/ticket modal directly.
  document.querySelectorAll('.keycap').forEach(btn => {
    btn.addEventListener('click', () => {
      const key = (btn as HTMLElement).dataset.key!
      window.dispatchEvent(new KeyboardEvent('keydown', { key }))
    })
  })

  // Visual feedback: flash the matching keycap on real key presses
  window.addEventListener('keydown', (e) => {
    const key = e.key.toLowerCase()
    const match = document.querySelector(`.keycap[data-key="${key === 'enter' ? 'Enter' : key}"]`) as HTMLElement | null
    if ('efgy'.includes(key) && !rickedRoll) {
      window.open('https://youtu.be/dQw4w9WgXcQ?si=XC9FTyur51K2qQU-', '_blank')
      rickedRoll = true
      gtag('event', 'rickroll', {
        'event_category': 'User Interaction',
        'event_label': 'Rickroll',
      })
    }
    if (!match) return
    match.classList.add('pressed')
    setTimeout(() => match.classList.remove('pressed'), 120)
    if (key === 't') {
      // Open register / ticket modal
      window.open('https://summit.g0v.tw/tickets', '_blank')
    }
  })
</script>
