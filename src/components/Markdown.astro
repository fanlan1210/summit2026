---
import { micromark } from 'micromark'

interface Props {
  content?: string | null
  class?: string
}

const { content = '', class: className = '' } = Astro.props
const html = micromark(content)

const baseClassName =
  'wrap-break-word leading-relaxed [&_a]:text-info-dark [&_a]:underline [&_blockquote]:border-l-4 [&_blockquote]:border-neutral-300 [&_blockquote]:pl-4 [&_code]:rounded [&_code]:bg-neutral-200 [&_code]:px-1 [&_code]:py-0.5 [&_h1]:mb-4 [&_h1]:font-bold [&_h2]:mb-4 [&_h2]:font-bold [&_h3]:mb-3 [&_h3]:font-bold [&_h4]:mb-3 [&_h4]:font-bold [&_h5]:mb-2 [&_h5]:font-bold [&_h6]:mb-2 [&_h6]:font-bold [&_li]:mb-1 [&_ol]:mb-4 [&_ol]:list-decimal [&_ol]:pl-6 [&_p]:mb-4 [&_p:last-child]:mb-0 [&_pre]:overflow-x-auto [&_pre]:rounded [&_pre]:bg-neutral-900 [&_pre]:p-4 [&_pre]:text-neutral-100 [&_ul]:mb-4 [&_ul]:list-disc [&_ul]:pl-6'
---

<div class:list={['markdown-content', baseClassName, className]} set:html={html} />
