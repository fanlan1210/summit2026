---
import Layout from '~/layouts/Layout.astro'
import { useI18n } from '~/i18n/utils'

const { t } = useI18n(Astro.url.pathname)
---

<Layout pageName={t('nav.visit')}>
  <div class="visit-main container mx-auto px-10 py-25">
    <!-- 區塊一：交通資訊 -->
    <div class="visit-section-info mb-16 grid gap-8 md:grid-cols-[1fr_1.8fr]">
      <div class="visit-section-info__title">
        <h2>{t('visit.info.title')}</h2>
      </div>
      <!-- 右側：地圖 -->
      <div class="visit-section-info__right md:row-span-2 min-h-0">
        <div class="visit-map-embed w-full h-full min-h-[400px] rounded bg-neutral-200 flex items-center justify-center text-neutral-500">
          {t('visit.info.mapPlaceholder')}
        </div>
      </div>
      <!-- 左側：地址與地圖按鈕 -->
      <div class="visit-section-info__content">
        <div class="visit-section-info__left flex flex-col justify-center">
          <div class="visit-venue-name mb-4 leading-relaxed">
            <h3 class="text-primary">{t('visit.info.venueName')}</h3>
          </div>
          <div class="visit-address leading-relaxed">
            <address>{t('visit.info.address')}</address>
          </div>
          <div class="visit-map-buttons flex flex-wrap gap-3 mt-8">
            <div class="visit-map-btn visit-map-btn--osm">
              <a href="#" class="btn">{t('visit.info.osmMap')}</a>
            </div>
            <div class="visit-map-btn visit-map-btn--google">
              <a href="#" class="btn">{t('visit.info.googleMap')}</a>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- 區塊二：交通方式 -->
    <div class="visit-section-transport">
      <div class="visit-section-transport__title mb-12">
        <h2>{t('visit.transport.title')}</h2>
      </div>
      <div class="visit-tabs">
        <!-- 標籤頁導航 -->
        <div class="visit-tabs__nav flex gap-6" role="tablist">
          <button type="button" class="visit-tabs__tab visit-tabs__tab--active flex min-w-[13rem] items-center justify-center gap-2 font-bold border-b-5 border-primary pb-2 cursor-pointer bg-transparent" role="tab" aria-selected="true" aria-controls="visit-panel-publicTransport" id="visit-tab-publicTransport" data-tab="publicTransport">
            <iconify-icon icon="mdi:bus" class="size-5 shrink-0" aria-hidden="true"></iconify-icon>
            <span>{t('visit.transport.tabs.publicTransport')}</span>
          </button>
          <button type="button" class="visit-tabs__tab flex min-w-[13rem] items-center justify-center gap-2 font-bold border-b-5 border-transparent pb-2 cursor-pointer bg-transparent" role="tab" aria-selected="false" aria-controls="visit-panel-driving" id="visit-tab-driving" data-tab="driving">
            <iconify-icon icon="mdi:car" class="size-5 shrink-0" aria-hidden="true"></iconify-icon>
            <span>{t('visit.transport.tabs.driving')}</span>
          </button>
        </div>
        <!-- 標籤頁內容 -->
        <div class="visit-tabs__content mt-8 min-h-[480px]">
          <!-- 大眾運輸 -->
          <div id="visit-panel-publicTransport" class="visit-tab-panel grid gap-8 md:grid-cols-2" role="tabpanel" aria-labelledby="visit-tab-publicTransport" data-panel="publicTransport">
            <div class="visit-tab-panel__left">
              <div class="visit-step">
                <div class="visit-step__title">
                  <h4>{t('visit.transport.step1.title')}</h4>
                </div>
                <ul class="visit-step__list">
                  <li>{t('visit.transport.step1.item1')}</li>
                  <li>{t('visit.transport.step1.item2')}</li>
                </ul>
              </div>
              <div class="visit-step">
                <div class="visit-step__title">
                  <h4>{t('visit.transport.step2.title')}</h4>
                </div>
                <ul class="visit-step__list">
                  <li>{t('visit.transport.step2.item1')}</li>
                  <li>{t('visit.transport.step2.item2')}</li>
                  <li>{t('visit.transport.step2.item3')}</li>
                  <li>{t('visit.transport.step2.item4')}</li>
                </ul>
              </div>
            </div>
            <div class="visit-tab-panel__right min-h-[320px]">
              <div class="visit-image-placeholder aspect-video min-h-[320px] w-full rounded bg-neutral-200 flex items-center justify-center text-neutral-500">
                {t('visit.transport.imagePlaceholder')}
              </div>
            </div>
          </div>
          <!-- 自行開車 -->
          <div id="visit-panel-driving" class="visit-tab-panel hidden grid gap-8 md:grid-cols-2" role="tabpanel" aria-labelledby="visit-tab-driving" data-panel="driving" aria-hidden="true">
            <div class="visit-tab-panel__left">
              <div class="visit-step">
                <div class="visit-step__title">
                  <h4>{t('visit.transport.drivingStep1.title')}</h4>
                </div>
                <ul class="visit-step__list">
                  <li>{t('visit.transport.drivingStep1.item1')}</li>
                </ul>
              </div>
              <div class="visit-step">
                <div class="visit-step__title">
                  <h4>{t('visit.transport.drivingStep2.title')}</h4>
                </div>
                <ul class="visit-step__list">
                  <li>{t('visit.transport.drivingStep2.item1')}</li>
                </ul>
              </div>
              <div class="visit-step">
                <div class="visit-step__title">
                  <h4>{t('visit.transport.drivingStep3.title')}</h4>
                </div>
                <ul class="visit-step__list">
                  <li>{t('visit.transport.drivingStep3.item1')}</li>
                </ul>
              </div>
            </div>
            <div class="visit-tab-panel__right min-h-[320px]">
              <div class="visit-image-placeholder aspect-video min-h-[320px] w-full rounded bg-neutral-200 flex items-center justify-center text-neutral-500">
                {t('visit.transport.imagePlaceholder')}
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <script src="../scripts/visit-tabs.js"></script>
  </div>
</Layout>
