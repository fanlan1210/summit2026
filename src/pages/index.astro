---
import Layout from '~/layouts/Layout.astro'
import Icon from '~/components/Icon.astro'
import Timeline from '~/components/Timeline.astro'
import PastEvent from '~/components/PastEvent.astro'
import Partner from '~/components/Partner.astro'
import Link from '~/components/Link.astro'
import { useI18n } from '~/i18n/utils'

const { t } = useI18n(Astro.url.pathname)
---

<Layout pageName={t('title')}>
  <div id="nav-transparent-flag" class="hidden"></div>

  <div id="top-block" class="relative flex h-[calc(100vh-56px)] w-full flex-col items-center overflow-hidden bg-[rgb(252,245,241)] md:h-[calc(100vh-112px)]">
    <div class="relative z-2 mx-auto mb-6 flex h-fit w-4/5 max-w-xl grow flex-col items-center justify-center md:w-1/2">
      <img class="mb-4 w-1/2 md:mb-6 md:w-1/3" src="./img/banner/g0v-summit-logo.svg" alt="g0v summit" />

      <img class="mb-4 md:mb-8" src="./img/banner/slogan.svg" alt="反客為主 Invite Yourself" />

      <img class="w-4/5 md:w-1/2" src="./img/banner/date-and-venue.svg" alt="2026.05.23–24 | Taipei, Taiwan" />
    </div>

    <div class="relative z-1 -mb-12 grid w-[120%] grid-cols-3 items-end gap-16 md:grid-cols-5">
      <img class="stool z-1 mx-auto hidden w-2/3 max-w-[220px] cursor-pointer md:block" src="./img/banner/g0v_stool-nbg-g-m.svg" alt="green-chair-1" data-stool="g" />

      <a class="stool-container relative z-2 mx-auto max-w-[220px] no-underline md:w-2/3" href="https://summit.g0v.tw/tickets" target="_blank" title="前往購票">
        <div class="speech-bubble">
          <Icon name="mdi:ticket" width="20" />
        </div>
        <img class="stool w-full cursor-pointer" src="./img/banner/g0v_stool-nbg-y-s.svg" alt="yellow-chair" data-stool="y" />
      </a>

      <a class="stool-container relative z-3 mx-auto max-w-[220px] no-underline md:w-2/3" href="https://summit.g0v.tw/tickets" target="_blank" title="前往購票">
        <div class="speech-bubble">
          <Icon name="mdi:ticket" width="20" />
        </div>
        <img class="stool w-full cursor-pointer" src="./img/banner/g0v_stool-nbg-r-l.svg" alt="red-chair" data-stool="r" />
      </a>

      <a class="stool-container relative z-4 mx-auto max-w-[220px] no-underline md:w-2/3" href="https://summit.g0v.tw/tickets" target="_blank" title="前往購票">
        <div class="speech-bubble">
          <Icon name="mdi:ticket" width="20" />
        </div>
        <img class="stool w-full cursor-pointer" src="./img/banner/g0v_stool-nbg-b-s.svg" alt="blue-chair" data-stool="b" />
      </a>

      <img class="stool z-5 mx-auto hidden w-2/3 max-w-[220px] cursor-pointer md:block" src="./img/banner/g0v_stool-nbg-g-m.svg" alt="green-chair-2" data-stool="g" />
    </div>

    <img class="object-fit h-24 max-w-none md:h-auto md:max-w-full" src="./img/banner/bottom-bar.svg" alt="banner-bottom-bar" />
  </div>

  <main>
    <div class="container py-20">
      <section id="intro" class="mb-20">
        <h1 class="mb-2 leading-relaxed md:mb-4">g0v Summit 2026</h1>

        <h2 class="mb-6 md:mb-12">{t('index.intro.title')}</h2>

        <div>
          <p set:html={t('index.intro.p1')} />
          <p set:html={t('index.intro.p2')} />
          <p set:html={t('index.intro.p3')} />
          <p set:html={t('index.intro.p4')} />
          <p set:html={t('index.intro.p5')} />
          <p set:html={t('index.intro.p6')} />
          <p set:html={t('index.intro.p7')} />
          <p set:html={t('index.intro.p8')} />
        </div>
      </section>

      <section id="timeline" class="mb-20">
        <Timeline />
      </section>

      <section id="location" class="mb-20">
        <h2 class="mb-8 text-3xl font-bold max-md:text-center md:text-4xl">
          {t('index.venue.title')}
        </h2>

        <p class="md:text-2xl">
          <div>{t('index.venue.name')}</div>
          <address>{t('index.venue.address')}</address>
          <Link href="visit" class="flex items-center gap-2">{t('visit.info.title')}<Icon name="mdi:arrow-right" width="18" height="18" /></Link>
          <div class="visit-map-embed relative mt-4 aspect-video w-full overflow-hidden rounded">
            <iframe
              title={t('visit.info.mapPlaceholder')}
              class="block h-full min-h-[450px] w-full border-0"
              referrerpolicy="no-referrer-when-downgrade"
              src="https://www.openstreetmap.org/export/embed.html?bbox=121.605%2C25.038%2C121.618%2C25.045&layer=mapnik&marker=25.041528%2C121.611472"
              loading="lazy"></iframe>
            <div class="visit-map-embed__overlay absolute inset-0 z-10 flex cursor-pointer items-center justify-center bg-black/40">
              <span class="text-white">{t('visit.info.mapView')}</span>
            </div>
          </div>

          <hr class="mb-20 text-neutral-300" />

          <section id="what-is" class="mb-20">
            <h2 class="mb-8 text-3xl font-bold max-md:text-center md:text-4xl">
              {t('index.g0vSummit.title')}
            </h2>

            <div>
              <p set:html={t('index.g0vSummit.p1')} />
              <p set:html={t('index.g0vSummit.p2')} />
              <p set:html={t('index.g0vSummit.p3')} />
              <p set:html={t('index.g0vSummit.p4')} />
              <p set:html={t('index.g0vSummit.p5')} />
              <p set:html={t('index.g0vSummit.p6')} />
              <p set:html={t('index.g0vSummit.p7')} />
            </div>
          </section>

          <section id="past-events" class="mb-20">
            <h2 class="mb-8 text-3xl font-bold max-md:text-center md:text-4xl">
              {t('index.pastEvents')}
            </h2>

            <div class="grid gap-4 md:grid-cols-3">
              <PastEvent year="2024" />
              <PastEvent year="2022" />
              <PastEvent year="2020" />
              <PastEvent year="2018" />
              <PastEvent year="2016" />
              <PastEvent year="2014" />
            </div>
          </section>

          <section id="join" class="mb-20">
            <h2 class="mb-8 text-3xl font-bold max-md:text-center md:text-4xl">
              {t('index.joinG0v.title')}
            </h2>

            <div class="mb-7">
              <p>{t('index.joinG0v.p1')}</p>
              <p set:html={t('index.joinG0v.p2')} />
            </div>

            <div class="flex flex-col justify-center gap-4 md:flex-row md:justify-start">
              <a class="btn btn-primary gap-2" href="https://join.g0v.tw" target="_blank">
                <span>{t('index.joinG0v.slack')}</span>
                <Icon name="material-symbols:open-in-new" width="20" height="20" />
              </a>

              <a class="btn btn-primary gap-2" href="https://g0v.hackmd.io/@summit2026/book" target="_blank">
                <span>{t('index.joinG0v.docs')}</span>
                <Icon name="material-symbols:open-in-new" width="20" height="20" />
              </a>

              <a class="btn btn-primary gap-2" href="https://g0v.hackmd.io/@jothon/event" target="_blank">
                <span>{t('index.joinG0v.events')}</span>
                <Icon name="material-symbols:open-in-new" width="20" height="20" />
              </a>
            </div>
          </section>
        </p>
      </section>
    </div>

    <script>
      document.querySelector('.visit-map-embed__overlay')?.addEventListener('click', function () {
        this.closest('.visit-map-embed')?.classList.add('visit-map-embed--active')
      })
      window.addEventListener('focus', function () {
        console.log('window on focus')
        document.querySelector('.visit-map-embed')?.classList.remove('visit-map-embed--active')
      })
    </script>

    <style>
      .visit-map-embed__overlay {
        opacity: 0;
        transition: opacity 0.1s ease-in-out;
        &:hover {
          opacity: 1;
        }
      }

      .visit-map-embed--active .visit-map-embed__overlay {
        pointer-events: none;
        opacity: 0;
      }
    </style>
  </main></Layout
>
