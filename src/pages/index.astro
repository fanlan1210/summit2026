---
import Layout from '~/layouts/Layout.astro'
import Icon from '~/components/Icon.astro'
import Timeline from '~/components/Timeline.astro'
import PastEvent from '~/components/PastEvent.astro'
import Link from '~/components/Link.astro'
import { useI18n } from '~/i18n/utils'
import ModelViewer from '../components/ModelViewer.astro'

const { t } = useI18n(Astro.url.pathname)
---

<link href="https://cdn.jsdelivr.net/npm/flipdown@0.3.2/dist/flipdown.min.css" rel="stylesheet" />
<Layout pageName={t('title')}>
  <div id="nav-transparent-flag" class="hidden"></div>
  <div class="h-[calc(50vh)] w-full md:h-[calc(100vh-56px)]">
    <ModelViewer modelPath="models/plastic-stool-r.glb" />
  </div>

  <main>
    <div class="container pt-10 pb-20">
      <section id="intro" class="mb-20">
        <h1 class="mb-2 leading-relaxed md:mb-4">g0v Summit 2026</h1>

        <h2 class="mb-6 md:mb-12">{t('index.intro.title')}</h2>

        <div>
          <p set:html={t('index.intro.p1')} />
          <p set:html={t('index.intro.p2')} />
          <p set:html={t('index.intro.p3')} />
          <p set:html={t('index.intro.p4')} />
          <p set:html={t('index.intro.p5')} />
          <p set:html={t('index.intro.p6')} />
          <p set:html={t('index.intro.p7')} />
          <p set:html={t('index.intro.p8')} />
        </div>
      </section>

      <section id="timeline" class="m10-20">
        <Timeline />
      </section>

      <div id="flipdown" class="flipdown mx-auto mb-20"></div>

      <section id="location" class="mb-20">
        <h2 class="mb-8 text-3xl font-bold max-md:text-center md:text-4xl">
          {t('index.venue.title')}
        </h2>

        <p class="md:text-2xl">
          <div>{t('index.venue.name')}</div>
          <address>{t('index.venue.address')}</address>
          <Link href="visit" class="flex items-center gap-2">{t('visit.info.title')}<Icon name="mdi:arrow-right" width="18" height="18" /></Link>
          <div class="visit-map-embed relative mt-4 aspect-video w-full overflow-hidden rounded">
            <iframe
              title={t('visit.info.mapPlaceholder')}
              class="block h-full w-full border-0"
              referrerpolicy="no-referrer-when-downgrade"
              src="https://www.openstreetmap.org/export/embed.html?bbox=121.605%2C25.038%2C121.618%2C25.045&layer=mapnik&marker=25.041528%2C121.611472"
              loading="lazy"></iframe>
            <div class="visit-map-embed__overlay absolute inset-0 z-10 flex cursor-pointer items-center justify-center bg-black/40">
              <span class="text-white">{t('visit.info.mapView')}</span>
            </div>
          </div>

          <hr class="mb-20 text-neutral-300" />

          <section id="what-is" class="mb-20">
            <h2 class="mb-8 text-3xl font-bold max-md:text-center md:text-4xl">
              {t('index.g0vSummit.title')}
            </h2>

            <div>
              <p set:html={t('index.g0vSummit.p1')} />
              <p set:html={t('index.g0vSummit.p2')} />
              <p set:html={t('index.g0vSummit.p3')} />
              <p set:html={t('index.g0vSummit.p4')} />
              <p set:html={t('index.g0vSummit.p5')} />
              <p set:html={t('index.g0vSummit.p6')} />
              <p set:html={t('index.g0vSummit.p7')} />
            </div>
          </section>

          <section id="past-events" class="mb-20">
            <h2 class="mb-8 text-3xl font-bold max-md:text-center md:text-4xl">
              {t('index.pastEvents')}
            </h2>

            <div class="grid gap-4 md:grid-cols-3">
              <PastEvent year="2024" />
              <PastEvent year="2022" />
              <PastEvent year="2020" />
              <PastEvent year="2018" />
              <PastEvent year="2016" />
              <PastEvent year="2014" />
            </div>
          </section>

          <section id="join" class="mb-20">
            <h2 class="mb-8 text-3xl font-bold max-md:text-center md:text-4xl">
              {t('index.joinG0v.title')}
            </h2>

            <div class="mb-7">
              <p>{t('index.joinG0v.p1')}</p>
              <p set:html={t('index.joinG0v.p2')} />
            </div>

            <div class="flex flex-col justify-center gap-4 md:flex-row md:justify-start">
              <a class="btn btn-primary gap-2" href="https://join.g0v.tw" target="_blank">
                <span>{t('index.joinG0v.slack')}</span>
                <Icon name="material-symbols:open-in-new" width="20" height="20" />
              </a>

              <a class="btn btn-primary gap-2" href="https://g0v.hackmd.io/@summit2026/book" target="_blank">
                <span>{t('index.joinG0v.docs')}</span>
                <Icon name="material-symbols:open-in-new" width="20" height="20" />
              </a>

              <a class="btn btn-primary gap-2" href="https://g0v.hackmd.io/@jothon/event" target="_blank">
                <span>{t('index.joinG0v.events')}</span>
                <Icon name="material-symbols:open-in-new" width="20" height="20" />
              </a>
            </div>
          </section>
        </p>
      </section>
    </div>
  </main>
</Layout>
<script is:inline src="https://cdn.jsdelivr.net/npm/flipdown@0.3.2/src/flipdown.min.js"></script>
<script>
  document.querySelector('.visit-map-embed__overlay')?.addEventListener('click', function () {
    this.closest('.visit-map-embed')?.classList.add('visit-map-embed--active')
  })
  window.addEventListener('focus', function () {
    document.querySelector('.visit-map-embed')?.classList.remove('visit-map-embed--active')
  })

  function initCountdown() {
    const targetDate = new Date('2026-05-23T00:00:00+08:00')
    const dateDiff = targetDate - new Date()
    const twoDaysFromNow = new Date().getTime() / 1000 + dateDiff / 1000
    new FlipDown(twoDaysFromNow).start()
  }
  initCountdown()
</script>

<style>
  .visit-map-embed__overlay {
    opacity: 0;
    transition: opacity 0.1s ease-in-out;
    &:hover {
      opacity: 1;
    }
  }

  .visit-map-embed--active .visit-map-embed__overlay {
    pointer-events: none;
    opacity: 0;
  }

  .speech-bubble {
    position: absolute;
    top: -2.5rem;
    left: 50%;
    transform: translateX(-50%);
    background: white;
    padding: 0.25rem 0.625rem;
    border-radius: 0.5rem;
    opacity: 0;
    transition: opacity 0.2s ease;
    pointer-events: none;
    white-space: nowrap;
    box-shadow: 0 2px 6px rgb(0 0 0 / 0.15);

    &::after {
      content: '';
      position: absolute;
      bottom: -0.4rem;
      left: 50%;
      transform: translateX(-50%);
      border-width: 0.4rem 0.4rem 0;
      border-style: solid;
      border-color: white transparent transparent;
    }
  }

  .stool-container:hover .speech-bubble {
    opacity: 1;
  }
</style>
