---
import Layout from '~/layouts/Layout.astro'
import { useI18n } from '~/i18n/utils'
import Venue3F from '~/components/Venue3F.astro'
import Venue4F from '~/components/Venue4F.astro'
import Link from '~/components/Link.astro'

const { t } = useI18n(Astro.url.pathname)
---

<Layout pageName={t('nav.venue')}>
  <main>
    <div class="container py-8 md:py-12">
      <h1 class="mb-8">{t('nav.venue')}</h1>
      <p class="mb-12" set:html={t('venue.description')} />
      <div class="mx-auto my-10 mb-20 max-w-3xl">
        <h2>3F</h2>
        <Venue3F />
      </div>
      <div class="mx-auto my-10 max-w-3xl px-6">
        <h2>4F</h2>
        <Venue4F />
      </div>
    </div>
  </main>
</Layout>
