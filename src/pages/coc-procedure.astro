---
import Layout from '~/layouts/Layout.astro'
import Icon from '~/components/Icon.astro'
import Link from '~/components/Link.astro'
import Procedure1 from '~/components/coc/Procedure1.astro'
import Procedure2 from '~/components/coc/Procedure2.astro'
import { useI18n, getLocaleFromPath } from '~/i18n/utils'

const { t } = useI18n(Astro.url.pathname)
const lang = getLocaleFromPath(Astro.url.pathname)
---

<Layout pageName={t('nav.cocProcedure')}>
  <main class="container py-8 md:py-12">
    <h1 class="mb-8">{t('nav.cocProcedure')}</h1>
    <div class="mb-16 flex flex-wrap items-center gap-2">
      <a class="btn btn-primary flex gap-1" target="_blank" href={`https://g0v.tw/coc/${lang === 'en' ? 'en' : ''}`}>{t('cocProcedure.g0vCoc')}<Icon name="mdi:external-link" width="22" /></a>
      <span>{t('cocProcedure.lastRevision')}</span>
    </div>
    <h2 class="mb-8">{t('cocProcedure.caseTypes')}</h2>
    <h3 class="mt-8 mb-6">{t('cocProcedure.violation.title')}</h3>
    <ul>
      <li>{t('cocProcedure.violation.period')}</li>
      <li>{t('cocProcedure.violation.target')}</li>
      <li set:html={t('cocProcedure.violation.content')} />
      <li>
        <span>{t('cocProcedure.violation.measures')}</span>
        <ul>
          <li>{t('cocProcedure.violation.measure1')}</li>
          <li>{t('cocProcedure.violation.measure2')}</li>
        </ul>
      </li>
    </ul>
    <h3 class="mt-8 mb-6">{t('cocProcedure.warning.title')}</h3>
    <ul>
      <li>{t('cocProcedure.warning.target')}</li>
      <li>{t('cocProcedure.warning.content')}</li>
      <li>
        {t('cocProcedure.warning.measures')}<ul>
          <li>{t('cocProcedure.warning.measure1')}</li>
          <li>{t('cocProcedure.warning.measure2')}</li>
        </ul>
      </li>
    </ul>
    <h3 class="mt-8 mb-6">{t('cocProcedure.outOfScope.title')}</h3>
    <ul>
      <li>
        {t('cocProcedure.outOfScope.item1')}<ul>
          <li set:html={t('cocProcedure.outOfScope.item1sub')} />
        </ul>
      </li>
      <li>
        {t('cocProcedure.outOfScope.item2')}<ul>
          <li>{t('cocProcedure.outOfScope.item2sub1')}</li>
          <li>{t('cocProcedure.outOfScope.item2sub2')}</li>
        </ul>
      </li>
      <li>
        {t('cocProcedure.outOfScope.item3')}<ul>
          <li>{t('cocProcedure.outOfScope.item3sub1')}</li>
          <li>{t('cocProcedure.outOfScope.item3sub2')}</li>
        </ul>
      </li>
    </ul>
    <h2 class="mt-16 mb-8" id="申訴方式">{t('cocProcedure.appeal.title')}</h2>
    <Procedure1 />
    <div class="my-6 grid gap-4 md:grid-cols-3">
      <div class="flex flex-col rounded-xl border border-neutral-200 bg-neutral-50 p-5">
        <div class="mb-2 text-sm font-semibold text-neutral-500">{t('cocProcedure.appeal.subject')}</div>
        <ul class="mb-4">
          <li>{t('cocProcedure.appeal.card1.li1')}</li>
          <li>{t('cocProcedure.appeal.card1.li2')}</li>
          <li>{t('cocProcedure.appeal.card1.li3')}</li>
        </ul>
        <div class="mt-auto mb-2 text-sm font-semibold text-neutral-500">{t('cocProcedure.appeal.writeTo')}</div>
        <p class="font-medium">{t('cocProcedure.appeal.card1.to')}</p>
        <a href="mailto:coc@summit.g0v.tw" class="break-all">coc@summit.g0v.tw</a>
      </div>
      <div class="flex flex-col rounded-xl border border-neutral-200 bg-neutral-50 p-5">
        <div class="mb-2 text-sm font-semibold text-neutral-500">{t('cocProcedure.appeal.subject')}</div>
        <ul class="mb-4">
          <li>{t('cocProcedure.appeal.card2.li1')}</li>
        </ul>
        <div class="mt-auto mb-2 text-sm font-semibold text-neutral-500">{t('cocProcedure.appeal.writeTo')}</div>
        <p class="font-medium">{t('cocProcedure.appeal.card2.to')}</p>
        <a href="mailto:coordinator@summit.g0v.tw" class="break-all">coordinator@summit.g0v.tw</a>
      </div>
      <div class="flex flex-col rounded-xl border border-neutral-200 bg-neutral-50 p-5">
        <div class="mb-2 text-sm font-semibold text-neutral-500">{t('cocProcedure.appeal.subject')}</div>
        <ul class="mb-4">
          <li>{t('cocProcedure.appeal.card3.li1')}</li>
        </ul>
        <div class="mt-auto mb-2 text-sm font-semibold text-neutral-500">{t('cocProcedure.appeal.writeTo')}</div>
        <p class="font-medium">{t('cocProcedure.appeal.card3.to')}</p>
        <a href="mailto:keeper@summit.g0v.tw" class="break-all">keeper@summit.g0v.tw</a>
      </div>
    </div>
    <h2 class="mt-16 mb-8">{t('cocProcedure.process.title')}</h2>
    <div class="my-6">
      <Procedure2 />
    </div>
    <ol>
      <li>
        {t('cocProcedure.process.step1')}
        <ul>
          <li>{t('cocProcedure.process.step1Ref')}<Link href="coc-procedure#申訴方式">{t('cocProcedure.process.step1RefLink')}</Link></li>
        </ul>
      </li>
      <li>
        {t('cocProcedure.process.step2')}<ul>
          <li>{t('cocProcedure.process.step2sub1')}</li>
          <li>{t('cocProcedure.process.step2sub2')}</li>
        </ul>
      </li>
      <li>{t('cocProcedure.process.step3')}</li>
      <li>
        {t('cocProcedure.process.step4')}<ul>
          <li>{t('cocProcedure.process.step4sub')}</li>
        </ul>
      </li>
    </ol>
    <h4 class="mt-8 mb-6">{t('cocProcedure.notes.title')}</h4>
    <ul>
      <li>{t('cocProcedure.notes.note1')}</li>
      <li>{t('cocProcedure.notes.note2')}</li>
      <li>{t('cocProcedure.notes.note3')}</li>
    </ul>
    <h2 class="mt-16 mb-8">{t('cocProcedure.members.title')}</h2>
    <div class="my-6 w-max overflow-x-auto rounded-xl border border-neutral-200">
      <table class="border-collapse text-left">
        <thead class="bg-neutral-50 text-sm tracking-wide text-neutral-600 uppercase">
          <tr>
            <th scope="col" class="px-5 py-3 font-semibold">{t('cocProcedure.members.colPosition')}</th>
            <th scope="col" class="px-5 py-3 font-semibold">{t('cocProcedure.members.colName')}</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-neutral-200">
          <tr class="">
            <td class="px-5 py-3 text-neutral-700"
              >{t('cocProcedure.members.pos1')}
              <span class="bg-primary/10 text-primary inline-flex rounded-full px-2.5 py-0.5 text-xs font-medium">{t('cocProcedure.members.badgeConvener')}</span>
            </td>
            <td class="px-5 py-3 font-medium">球魚 </td>
          </tr>
          <tr class="">
            <td class="px-5 py-3 text-neutral-700">{t('cocProcedure.members.pos2')}</td>
            <td class="px-5 py-3 font-medium">RS</td>
          </tr>
          <tr class="">
            <td class="px-5 py-3 text-neutral-700">{t('cocProcedure.members.pos3')}</td>
            <td class="px-5 py-3 font-medium">pm5</td>
          </tr>
          <tr class="">
            <td class="px-5 py-3 text-neutral-700">{t('cocProcedure.members.pos4')}</td>
            <td class="px-5 py-3 font-medium">yellowsoar</td>
          </tr>
          <tr class="">
            <td class="px-5 py-3 text-neutral-700">{t('cocProcedure.members.pos5')}</td>
            <td class="px-5 py-3 font-medium">Winnie</td>
          </tr>
          <tr class="">
            <td class="px-5 py-3 text-neutral-700">{t('cocProcedure.members.pos6')}</td>
            <td class="px-5 py-3 font-medium">方塊酥</td>
          </tr>
          <tr class="">
            <td class="px-5 py-3 text-neutral-400">
              - <span class="bg-primary/10 text-primary inline-flex rounded-full px-2.5 py-0.5 text-xs font-medium">{t('cocProcedure.members.badgeExternal')}</span>
            </td>
            <td class="px-5 py-3 font-medium">Tiff </td>
          </tr>
        </tbody>
      </table>
    </div>
    <p class="mt-16" set:html={t('cocProcedure.discussion')} />
    <p>{t('cocProcedure.effectiveDate')}</p>
  </main>
</Layout>

