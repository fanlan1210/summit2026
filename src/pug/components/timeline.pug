h2(class="max-md:text-center text-3xl md:text-4xl mb-12 font-bold" data-i18n="index.t2") 重要日程
div(class="flex flex-wrap gap-8 mb-12 md:gap-x-3 justify-center items-center")
  mixin timelineItem(text, dateText, date, i18nKey, showArrow=true)
    div(class="timeline-item flex flex-col items-center gap-1 self-start max-md:w-full" data-timeline-date=date)
      div(class="timeline-icon w-22 h-22 border rounded-full flex")
      span(class="font-bold text-xl md:text-2xl text-neutral-400")!= dateText
      h3(class="timeline-item-title text-2xl md:text-3xl font-bold text-center max-w-48" data-i18n=`[html]index.dates.${i18nKey}.title`)= text
    if showArrow
      div(class="hidden md:block")
        img(src="https://api.iconify.design/material-symbols/arrow-right-alt-rounded.svg" width="44" height="44")
  
  +timelineItem("徵件開始", "<ruby>2025/12/15<rt>&nbsp;</rt></ruby>", "2025/12/15", 1)
  +timelineItem("徵件截止", "2026/01/15<ruby> 23:59<rt>(UTC+8)</rt></ruby>", "2026/01/15", 2)
  +timelineItem("通知投稿結果", "<ruby>2026/02/15<rt>&nbsp;</rt></ruby>", "2026/02/15", 3)
  +timelineItem("公告議程", "<ruby>2026/03/15<rt>&nbsp;</rt></ruby>", "2026/03/15", 4)
  +timelineItem("g0v Summit 2026", "<ruby>2026/05/23-24<rt>&nbsp;</rt></ruby>", "2026/05/23", 5, false)