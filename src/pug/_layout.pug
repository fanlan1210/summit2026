block variables
doctype
html(lang="zh-Hant-TW")
  head
    title(data-i18n=`${pageKey}.meta.title`) #{title} | g0v Summit 2026
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1.0")
    meta(http-equiv="X-UA-Compatible", content="ie=edge")
    meta(property='og:description', content='g0v Summit 2026 是 g0v 台灣零時政府社群兩年一次的大聚會，也是全球公民黑客、公民科技的盛會。民主不只投票凍蒜，Summit 2026 邀你一起持續貢獻、全球連結，公民不打烊。')
    meta(property='og:image', content="assets/img/summit2026cfp.jpg")

    base(href=base)
    link(rel='icon', type='image/svg', href='assets/img/stool-nbg-r-l.svg')
    link(rel='preconnect', href='https://fonts.googleapis.com')
    link(rel='preconnect', href='https://fonts.gstatic.com', crossorigin)
    link(href='https://fonts.googleapis.com/css2?family=Amarna:ital,wght@0,100..700;1,100..700&family=Noto+Sans+TC:wght@100..900&family=LXGW+WenKai+TC&display=swap', rel='stylesheet')
    link(rel='stylesheet', href='assets/css/base.css?version='+timestamp)
    link(rel='stylesheet', href='assets/css/index.css?version='+timestamp)
    block head
  body
    nav#navbar(class="fixed z-999 grid place-items-center w-full h-14 md:h-28 font-serif")
      div(class="container flex items-center") 
        a(class="btn btn-lg btn-text-dark mr-auto !font-black" href="./") g0v Summit 2026
        div(class="hidden md:flex items-center gap-6 lg:gap-12")
          a(class="btn btn-lg btn-text-dark !font-black" href="#" data-i18n="nav.summit_info") 年會資訊
          a(class="btn btn-lg btn-primary !font-black" href="./guidelines" data-i18n="nav.cfp") 徵稿辦法
          div(class="flex items-center gap-2 text-xl font-black")
            iconify-icon(icon="material-symbols:globe-asia" width="24" height="24")
            button(class="lang-btn zh-btn") 華語
            span |
            button(class="lang-btn en-btn") English
        button#toggle-nav-btn(class="md:hidden grid place-items-center")
          iconify-icon(icon="material-symbols:clear-all-rounded" width="32" height="32")
      div#mobile-nav(class="md:hidden absolute left-0 right-0 top-full overflow-hidden bg-white grid grid-rows-[0fr] transition-[grid-template-rows]")
        div(class="min-h-0")
          div(class="flex flex-col gap-3 items-center py-4")
            a(class="text-xl font-bold font-bold no-underline" href="#" data-i18n="nav.summit_info") 年會資訊
            a(class="h-12 grid place-items-center px-4 text-xl font-bold text-white bg-primary no-underline rounded-2xl whitespace-nowrap" href="./guidelines" data-i18n="nav.cfp") 徵稿辦法
            div(class="flex items-center gap-2 text-xl py-2")
              iconify-icon(icon="material-symbols:globe-asia" width="24" height="24")
              button(class="lang-btn zh-btn") 華語
              span |
              button(class="lang-btn en-btn") English

    block main

    footer.bg-slate-100: .container.py-20
      nav(class="grid gap-8 grid-cols-2 md:grid-cols-4", aria-label="Sitemap")
        .leading-loose
          .mb-4.font-bold Summit 2026
          a.block(href="speakers", data-i18n="nav.speakers") 講者
          a.block(href="agenda", data-i18n="nav.agenda") 議程
          a.block(href="visit", data-i18n="nav.visit") 交通
          a.block(href="//g0v.hackmd.io/@summit2026/notes", target="_blank", data-i18n="nav.hackmd") 共筆
          a.block(href="//www.youtube.com/@g0vTW", target="_blank", data-i18n="nav.live") 直播
        .leading-loose
          .mb-4.font-bold(data-i18n="nav.media") 媒體資源
          a.block(href="//g0v.hackmd.io/@SQLfOC1bRwKstcPS84Gu_w/H1aRf_W8a", target="_blank", data-i18n="nav.presskit") 新聞素材
          a.block(href="guide", data-i18n="nav.guide") 行前資訊
          a.block(href="//us21.campaign-archive.com/home/?u=5f2da7dc5b32fcf00c4e26170&id=cf109d5e52", target="_blank", data-i18n="nav.newsletter") 電子報
          a.block(href="souvenir", data-i18n="nav.souvenir") 紀念品
        .leading-loose
          .mb-4.font-bold(data-i18n="nav.about") 關於 Summit
          a.block(href="staff", data-i18n="nav.staff") 工作團隊
          a.block(href="partners", data-i18n="nav.partners") 合作夥伴
          a.block(href="//g0v.hackmd.io/@summit2026/book/", target="_blank", data-i18n="nav.docs") 籌備紀錄
          a.block(href="coc", data-i18n="nav.coc") 社群守則
          a.block(href="safety", data-i18n="nav.safety") 安全須知
        .leading-loose
          .mb-4.font-bold(data-i18n="nav.past") 歷年網站
          a.block(href="//summit.g0v.tw/2024", target="_blank") 2024
          a.block(href="//summit.g0v.tw/2020", target="_blank") 2020
          a.block(href="//summit.g0v.tw/2018", target="_blank") 2018
          a.block(href="//summit.g0v.tw/2016", target="_blank") 2016
          a.block(href="//summit.g0v.tw/2014", target="_blank") 2014
      .mt-16.flex.flex-wrap
        span CC BY 4.0 @ g0v Summit 2026
        a(class="mr-16 md:ml-8", href="//github.com/g0v/summit2026/issues", target="_blank", data-i18n="nav.bugreport") 網站問題回饋
