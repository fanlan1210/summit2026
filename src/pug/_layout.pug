block variables
doctype
html(lang="zh-Hant-TW")
  head
    title(data-i18n=`${pageKey}.meta.title`) #{title} | g0v Summit 2026
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1.0")
    meta(http-equiv="X-UA-Compatible", content="ie=edge")
    if noindex
      meta(name="robots" content="noindex")
    else
      //  Google tag (gtag.js)
      script(async src='https://www.googletagmanager.com/gtag/js?id=G-SPHXWCG6TN')
      script.
        window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          gtag('js', new Date());
          gtag('config', 'G-SPHXWCG6TN');
    meta(name='description', content='g0v Summit 2026 是 g0v 台灣零時政府社群兩年一次的大聚會，也是全球公民科技、公民行動、開放資料、數位治理實踐者齊聚一堂的盛會。不論你是想來傳承經驗或是揪團打怪，歡迎你拉張板凳、拋出糸索，一起加入這場公民phah-ty！')
    meta(property='og:title', content=`${title} | g0v Summit 2026`)
    meta(property='og:description', content='g0v Summit 2026 是 g0v 台灣零時政府社群兩年一次的大聚會，也是全球公民科技、公民行動、開放資料、數位治理實踐者齊聚一堂的盛會。不論你是想來傳承經驗或是揪團打怪，歡迎你拉張板凳、拋出糸索，一起加入這場公民phah-ty！')
    meta(property='og:image', content="https://summit.g0v.tw/2026/assets/img/share.jpg")
    meta(property='og:url', content="https://summit.g0v.tw/2026")
    meta(property='og:type', content="website")
    meta(name='twitter:card', content='summary_large_image')
    meta(name='twitter:title', content=`${title} | g0v Summit 2026`)
    meta(name='twitter:description', content='g0v Summit is centered on “Information Transparency, Open Results, and Open Collaboration,” we use the power of the grassroots to care for public affairs. In 2026, #🪑InviteYourself to Taipei to weave the future of civic space.')
    meta(name='twitter:image', content="https://summit.g0v.tw/2026/assets/img/share.jpg")
    base(href=base)
    link(rel='icon', type='image/svg', href='assets/img/stools/stool-nbg-r-l.svg')
    link(rel='preconnect', href='https://fonts.googleapis.com')
    link(rel='preconnect', href='https://fonts.gstatic.com', crossorigin)
    link(href='https://fonts.googleapis.com/css2?family=Onest:wght@100..900&family=Noto+Sans+TC:wght@100..900&display=swap', rel='stylesheet')
    link(href='https://cdn.jsdelivr.net/npm/flipdown@0.3.2/dist/flipdown.min.css', rel='stylesheet')
    link(rel='stylesheet', href='assets/css/base.css?version='+timestamp)
    block head
    body
      canvas#overlap-canvas(class="fixed z-998 w-full h-full pointer-events-none")
      nav#navbar(class="sticky top-0 z-999 flex items-center w-full bg-black text-white shadow-md h-14")
        div(class="container flex items-center")
          a#logo(class="btn btn-lg btn-text-dark mr-auto" href="./")
            img(src="assets/img/g0v-summit-logo-w.svg", alt="g0v Summit 2026", class="h-12")
          div(class="hidden md:flex items-center gap-1")
            a(class="btn" href="" data-i18n="nav.agenda") 議程
            a(class="btn" href="" data-i18n="nav.visit") 交通
            a(class="btn" href="" data-i18n="nav.venue") 場地與攤位
            a(class="btn" href="" data-i18n="nav.speaker") 講者
            a(class="btn" href="" data-i18n="nav.sponsor") 贊助/媒體
            a(class="btn" href="" data-i18n="nav.about") 關於
          button#toggle-nav-btn(class="md:hidden grid place-items-center h-6")
            #burger
          div#mobile-nav(class="md:hidden absolute left-0 right-0 top-full overflow-hidden bg-white grid grid-rows-[0fr] transition-[grid-template-rows]")
            div(class="min-h-0")
              div(class="flex flex-col gap-3 items-center")
                a(class="toggle-mobile-nav btn btn-text-dark" href="#intro" data-i18n="nav.summit_info") 年會資訊
                a(class="toggle-mobile-nav btn btn-text-dark" href="./guidelines" data-i18n="nav.cfp") 徵稿辦法
                a(class="toggle-mobile-nav btn btn-primary" href="https://g0v-summit-2026.oen.tw/" target="_blank" data-i18n="nav.donate") 支持 Summit
                div(class="flex items-center gap-2 text-xl py-2")
                  iconify-icon(icon="material-symbols:globe-asia" width="24" height="24")
                  button(class="lang-btn zh-btn") 華語
                  span |
                  button(class="lang-btn en-btn") English

        div(class="flex h-full pe-6 items-center gap-2 font-bold group relative")
          span(class="flex items-center gap-2") Language 
            iconify-icon(icon="mdi:language" width="18" height="18")
          div(class="opacity-0 group-hover:opacity-100 pointer-events-none group-hover:pointer-events-auto transition-[opacity,transform] transform-[translateY(90%)] group-hover:transform-[translateY(100%)] absolute top-0 left-0 bottom-0 right-0 w-max block")
            div(class="mt-1")
              div(class="cursor-pointer px-6 py-2 bg-black text-white lang-btn zh-btn w-full") 華語
              div(class="cursor-pointer px-6 py-2 bg-black text-white lang-btn en-btn w-full") En
        a(class="bg-brand h-full hidden md:flex items-center justify-center px-8 flex-shrink-0" href="#") 參與活動
      main
        block main

      footer.bg-slate-100: .container.py-20
        nav(class="grid gap-8 grid-cols-2 md:grid-cols-4", aria-label="Sitemap")
          div(class="leading-loose grid h-fit")
            .mb-4.font-bold Summit 2026
            a(href="", data-i18n="nav.speakers" disabled) 講者
            a(href="", data-i18n="nav.agenda" disabled) 議程
            a(href="", data-i18n="nav.visit" disabled) 交通
            a(href="", target="_blank", data-i18n="nav.hackmd" disabled) 共筆
            a(href="", target="_blank", data-i18n="nav.live" disabled) 直播
          div(class="leading-loose grid h-fit")
            .mb-4.font-bold(data-i18n="nav.media") 媒體資源
            a(href="https://g0v.hackmd.io/@summit2026/press-kit", target="_blank", data-i18n="nav.presskit") 新聞素材
            a(href="", data-i18n="nav.guide" disabled) 行前資訊
            a(href="", target="_blank", data-i18n="nav.newsletter" disabled) 電子報
            a(href="", data-i18n="nav.souvenir" disabled) 紀念品
          div(class="leading-loose grid h-fit")
            .mb-4.font-bold(data-i18n="nav.about") 關於 Summit
            a(href="", data-i18n="nav.staff" disabled) 工作團隊
            a(href="", data-i18n="nav.partners" disabled) 合作夥伴
            a(href="https://g0v.hackmd.io/@summit2026/book/", target="_blank", data-i18n="nav.docs") 籌備紀錄
            a(href="https://g0v.hackmd.io/@summit2026/coc-procedure", data-i18n="nav.coc") 社群守則
            a(href="", data-i18n="nav.safety" disabled) 安全須知
          div(class="leading-loose grid h-fit")
            .mb-4.font-bold(data-i18n="nav.past") 歷年網站
            a(href="//summit.g0v.tw/2024", target="_blank") 2024
            a(href="//summit.g0v.tw/2020", target="_blank") 2020
            a(href="//summit.g0v.tw/2018", target="_blank") 2018
            a(href="//summit.g0v.tw/2016", target="_blank") 2016
            a(href="//summit.g0v.tw/2014", target="_blank") 2014
        .mt-16.flex.flex-wrap.gap-2
          span CC BY 4.0 @ g0v Summit 2026
          a(class="mr-16 md:ml-8", href="//github.com/g0v/summit2026/issues", target="_blank", data-i18n="nav.bugreport") 網站問題回饋
          .rolling-list.flex.gap-4
            a(href='https://www.facebook.com/g0v.tw/' target='_blank')
              iconify-icon(icon="ri:facebook-fill" width="30" height="30")
            a(href='https://www.instagram.com/g0v.tw/' target='_blank')
              iconify-icon(icon="ri:instagram-line" width="30" height="30")
            a(href='https://x.com/g0vtw/' target='_blank')
              iconify-icon(icon="ri:twitter-x-line" width="30" height="30")
            a(href='https://g0v.social/@summit' target='_blank')
              iconify-icon(icon="ri:mastodon-fill" width="30" height="30")
      #cookie-notice(class="fixed bottom-0 w-full bg-slate-200 flex p-4 items-center justify-center z-50 hidden" role='dialog' aria-label='Cookie' style="box-shadow: 0 4px 6px 4px rgba(0, 0, 0, 0.1)")
        div(data-i18n='cookie') 本網站使用 cookies 於廣告、社群與分析等用途，藉以增進您的使用體驗，繼續使用本網站即代表您同意使用 cookies。
        button.btn.btn-primary.shrink-0.my-auto.ms-3(data-i18n='agree') 同意
      if noindex
        #staging-info(class="fixed z-50 bottom-0 left-0 w-full bg-orange-400 text-white text-center") This is staging site. Please check #[a(href="https://summit.g0v.tw/") https://summit.g0v.tw/]
      script(src='https://code.jquery.com/jquery-3.7.0.min.js', integrity='sha256-2Pmvv0kuTBOenSvLm6bvfBSSHrUJ+3A7x6P5Ebd07/g=', crossorigin='anonymous')
      script(src='https://cdn.jsdelivr.net/npm/i18next@21.6.10/i18next.min.js')
      script(src='https://cdn.jsdelivr.net/npm/jquery-i18next@1.2.1/jquery-i18next.min.js')
      script(src="https://cdn.jsdelivr.net/npm/iconify-icon@3.0.0/dist/iconify-icon.min.js")
      script(src="https://cdn.jsdelivr.net/npm/flipdown@0.3.2/src/flipdown.min.js")
      script(src='assets/js/matter.min.js')
      script(src='assets/js/base.js?v='+timestamp)
      script(src='assets/js/overlap-canvas.js?v='+timestamp)
      block script
