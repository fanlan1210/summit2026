block variables
doctype
html(lang="zh-Hant-TW")
  head
    title #{title} | g0v Summit 2026
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1.0")
    meta(http-equiv="X-UA-Compatible", content="ie=edge")
    meta(property='og:description', content='g0v Summit 2026 是 g0v 台灣零時政府社群兩年一次的大聚會，也是全球公民黑客、公民科技的盛會。民主不只投票凍蒜，Summit 2026 邀你一起持續貢獻、全球連結，公民不打烊。')
    meta(property='og:image', content="assets/img/summit2026cfp.jpg")

    base(href=base)
    link(rel='icon', type='image/png', href='assets/img/icon.png')
    link(rel='preconnect', href='https://fonts.googleapis.com')
    link(rel='preconnect', href='https://fonts.gstatic.com', crossorigin)
    link(rel='stylesheet', href='https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200')
    link(href='https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@300;400;500;700&family=Onest:wght@100..900&display=swap', rel='stylesheet')
    script(src='https://kit.fontawesome.com/709050e76d.js' crossorigin='anonymous')
    link(rel='stylesheet', href='assets/css/base.css?version='+timestamp)
    link(rel='stylesheet', href='assets/css/index.css?version='+timestamp)
    block head
  body
    select#lang-select.fixed.right-0.top-0.z-50.bg-white
      option(value="zh") 華語
      option(value="en") English
    block main
    footer.bg-slate-100: .container.py-20
      nav.grid.gap-8(class="grid-cols-2 md:grid-cols-4", aria-label="Sitemap")
        .leading-loose
          .mb-4.font-bold Summit 2026
          a.block(href="speakers", data-i18n="nav.speakers") 講者
          a.block(href="agenda", data-i18n="nav.agenda") 議程
          a.block(href="visit", data-i18n="nav.visit") 交通
          a.block(href="//g0v.hackmd.io/@summit2026/notes", target="_blank", data-i18n="nav.hackmd") 共筆
          a.block(href="//www.youtube.com/@g0vTW", target="_blank", data-i18n="nav.live") 直播
        .leading-loose
          .mb-4.font-bold(data-i18n="nav.media") 媒體資源
          a.block(href="//g0v.hackmd.io/@SQLfOC1bRwKstcPS84Gu_w/H1aRf_W8a", target="_blank", data-i18n="nav.presskit") 新聞素材
          a.block(href="guide", data-i18n="nav.guide") 行前資訊
          a.block(href="//us21.campaign-archive.com/home/?u=5f2da7dc5b32fcf00c4e26170&id=cf109d5e52", target="_blank", data-i18n="nav.newsletter") 電子報
          a.block(href="souvenir", data-i18n="nav.souvenir") 紀念品
        .leading-loose
          .mb-4.font-bold(data-i18n="nav.about") 關於 Summit
          a.block(href="staff", data-i18n="nav.staff") 工作團隊
          a.block(href="partners", data-i18n="nav.partners") 合作夥伴
          a.block(href="//g0v.hackmd.io/@summit2026/book/", target="_blank", data-i18n="nav.docs") 籌備紀錄
          a.block(href="coc", data-i18n="nav.coc") 社群守則
          a.block(href="safety", data-i18n="nav.safety") 安全須知
        .leading-loose
          .mb-4.font-bold(data-i18n="nav.past") 歷年網站
          a.block(href="//summit.g0v.tw/2024", target="_blank") 2024
          a.block(href="//summit.g0v.tw/2020", target="_blank") 2020
          a.block(href="//summit.g0v.tw/2018", target="_blank") 2018
          a.block(href="//summit.g0v.tw/2016", target="_blank") 2016
          a.block(href="//summit.g0v.tw/2014", target="_blank") 2014
      .mt-16.flex.flex-wrap
        span CC BY 4.0 @ g0v Summit 2026
        a.ml-8.mr-16(href="//github.com/g0v/summit2026/issues", target="_blank", data-i18n="nav.bugreport") 網站問題回饋
        .rolling-list.flex.gap-4
          a(href='https://www.facebook.com/g0v.tw/' target='_blank')
            i.fa-brands.fa-facebook-f#social(aria-hidden='true')
          a(href='https://www.instagram.com/g0v.tw/' target='_blank')
            i.fa-brands.fa-instagram#social(aria-hidden='true')
          a(href='https://x.com/g0vtw/' target='_blank')
            i.fa-brands.fa-x-twitter#social(aria-hidden='true')
          a(href='https://g0v.social/@summit' target='_blank')
            i.fa-brands.fa-mastodon#social(aria-hidden='true')
    #cookie-notice.px-4.py-2.fixed.bottom-0.w-full.bg-white.flex.hidden(style="box-shadow: 0 4px 6px 4px rgba(0, 0, 0, 0.1)")
      .mr-auto 
        | 本網站使用 cookies 於廣告、社群與分析等用途，藉以增進您的使用體驗，繼續使用本網站即代表您 
        a(href="#") 同意使用 cookies
      button.btn.btn-primary.btn-sm(href="#") 同意 
      
    script(src='https://code.jquery.com/jquery-3.7.0.min.js', integrity='sha256-2Pmvv0kuTBOenSvLm6bvfBSSHrUJ+3A7x6P5Ebd07/g=', crossorigin='anonymous')
    script(src='https://cdnjs.cloudflare.com/ajax/libs/jquery.i18n/1.0.9/jquery.i18n.min.js', integrity='sha512-EkS8Kq86l7dHt/dOBniHgtYvAScDqFw/lIPX5VCwaVKsufs0pY44I2cguqZ45QaFOGGwVd3T1nXvVJYIEjRsjA==', crossorigin='anonymous', referrerpolicy='no-referrer')
    script(src='https://cdnjs.cloudflare.com/ajax/libs/jquery.i18n/1.0.9/jquery.i18n.emitter.bidi.min.js', integrity='sha512-EP79zV22G1pPO28sRgwfVyEPEhu1RXA2ovHJNqlev1pIGEAs0CBzi6F6UMkPBaPS78O3KeEVqpicEYah+zbXhg==', crossorigin='anonymous', referrerpolicy='no-referrer')
    script(src='https://cdnjs.cloudflare.com/ajax/libs/jquery.i18n/1.0.9/jquery.i18n.emitter.min.js', integrity='sha512-FXATL79ewicv4U54AgQVVHBBsinKwHuIZJZFUIJqhqpA6UV0XuAFAhTjGuA9JX0HmzwKW+frVH2MuHCzpDgSMQ==', crossorigin='anonymous', referrerpolicy='no-referrer')
    script(src='https://cdnjs.cloudflare.com/ajax/libs/jquery.i18n/1.0.9/jquery.i18n.fallbacks.min.js', integrity='sha512-FvKl0c+LXuYS0OlbGXHLIt/VUxLHgVG2wMHB8BwMDzEwwNACtxhutxl4jxlnuNfEuzKPLarLsf17UP7UgPMs6w==', crossorigin='anonymous', referrerpolicy='no-referrer')
    script(src='https://cdnjs.cloudflare.com/ajax/libs/jquery.i18n/1.0.9/jquery.i18n.language.min.js', integrity='sha512-XaRK7YZ6nqPsjMAMUysMC0J7zqEOp3K74pUzIADUd3Ql8qpFpuwpR5jm+TVyzJc8C5fvVkjC3yOjF0gWmmCtDA==', crossorigin='anonymous', referrerpolicy='no-referrer')
    script(src='https://cdnjs.cloudflare.com/ajax/libs/jquery.i18n/1.0.9/jquery.i18n.messagestore.min.js', integrity='sha512-Ejnbo8F6SIU18Tj9hZyJzVbhWtbC40Fyvuyfs6InZloy043xEvICul37BxuUGZG1ia8RQky7uBOwBdLsGKDu1w==', crossorigin='anonymous', referrerpolicy='no-referrer')
    script(src='https://cdnjs.cloudflare.com/ajax/libs/jquery.i18n/1.0.9/jquery.i18n.parser.min.js', integrity='sha512-v3mCT0T3rETWJU4RZKWHobzvOdJUcaojtxFBYVY371L/3aaWj9Dg2MNl6Q46wr19u4YHHnyzAR99wWAr9mB3ZA==', crossorigin='anonymous', referrerpolicy='no-referrer')
    script(src='assets/js/base.js?v='+timestamp)
    block script